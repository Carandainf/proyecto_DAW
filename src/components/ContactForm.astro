---
// src/components/ContactForm.astro
---

<form id="contactForm" class="space-y-4">
  <div class="hidden" aria-hidden="true">
    <input type="text" name="website_url" tabindex="-1" autocomplete="off" />
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div class="flex flex-col gap-1.5">
      <label class="text-[10px] uppercase tracking-widest text-slate-400 font-bold ml-1"
        >Nombre</label
      >
      <input
        name="nombre"
        type="text"
        placeholder="Ej. Clínica Dental Sol"
        required
        class="w-full bg-dent-dark border border-dent-border text-slate-200 p-3 rounded-xl text-xs outline-none focus:border-dent-accent focus:ring-1 focus:ring-dent-accent/30 transition-all shadow-inner"
      />
    </div>
    <div class="flex flex-col gap-1.5">
      <label class="text-[10px] uppercase tracking-widest text-slate-400 font-bold ml-1"
        >Email</label
      >
      <input
        name="email"
        type="email"
        placeholder="doctor@ejemplo.com"
        required
        class="w-full bg-dent-dark border border-dent-border text-slate-200 p-3 rounded-xl text-xs outline-none focus:border-dent-accent focus:ring-1 focus:ring-dent-accent/30 transition-all shadow-inner"
      />
    </div>
  </div>

  <div class="flex flex-col gap-1.5">
    <label class="text-[10px] uppercase tracking-widest text-slate-400 font-bold ml-1">Asunto</label
    >
    <input
      name="asunto"
      type="text"
      placeholder="¿En qué podemos ayudarte?"
      required
      class="w-full bg-dent-dark border border-dent-border text-slate-200 p-3 rounded-xl text-xs outline-none focus:border-dent-accent focus:ring-1 focus:ring-dent-accent/30 transition-all shadow-inner"
    />
  </div>

  <div class="flex flex-col gap-1.5">
    <label class="text-[10px] uppercase tracking-widest text-slate-400 font-bold ml-1"
      >Mensaje</label
    >
    <textarea
      name="mensaje"
      rows="4"
      placeholder="Describe tu consulta detalladamente..."
      required
      class="w-full bg-dent-dark border border-dent-border text-slate-200 p-3 rounded-xl text-xs outline-none focus:border-dent-accent focus:ring-1 focus:ring-dent-accent/30 transition-all shadow-inner resize-none"
    ></textarea>
  </div>

  <div class="bg-dent-dark/50 p-3 rounded-xl border border-dent-border/50">
    <div class="flex items-start gap-3">
      <input
        type="checkbox"
        id="privacy"
        required
        class="mt-1 w-4 h-4 rounded border-dent-border bg-dent-dark text-dent-accent focus:ring-dent-accent"
      />
      <label for="privacy" class="text-[10px] text-slate-400 leading-relaxed">
        Acepto que mis datos sean tratados para gestionar esta consulta. He leído la
        <a href="/privacidad" class="text-dent-accent hover:underline font-bold"
          >Política de Privacidad</a
        >.
      </label>
    </div>
  </div>

  <button
    type="submit"
    id="submitBtn"
    class="w-full py-4 bg-dent-accent text-dent-dark font-black rounded-xl text-xs uppercase tracking-[0.2em] hover:bg-cyan-400 active:scale-[0.98] transition-all shadow-lg shadow-dent-accent/20 flex justify-center items-center gap-2"
  >
    <span>Enviar Mensaje</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="w-4 h-4"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="3"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><path d="m22 2-7 20-4-9-9-4Z"></path><path d="M22 2 11 13"></path></svg
    >
  </button>

  <div
    id="formStatus"
    class="hidden p-3 rounded-xl text-[10px] font-bold uppercase tracking-widest text-center"
  >
  </div>
</form>

<script>
  const form = document.getElementById("contactForm") as HTMLFormElement;
  const status = document.getElementById("formStatus");
  const btn = document.getElementById("submitBtn") as HTMLButtonElement;

  // Asegurarnos de que el mensaje esté oculto al cargar la página (por si acaso)
  if (status) status.classList.add("hidden");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const formData = new FormData(form);

    if (formData.get("website_url")) {
      console.warn("Spam detectado.");
      return;
    }

    btn.disabled = true;
    const originalText = btn.innerHTML;
    btn.textContent = "Enviando...";

    const data = Object.fromEntries(formData);

    try {
      const res = await fetch("/api/contacto/enviar", {
        method: "POST",
        body: JSON.stringify(data),
        headers: { "Content-Type": "application/json" },
      });

      if (res.ok) {
        // Mostramos el mensaje de éxito
        status!.textContent = "✓ Mensaje enviado correctamente";
        status!.className =
          "p-3 rounded-xl text-[10px] font-bold uppercase tracking-widest text-center bg-emerald-500/10 text-emerald-500 block animate-fade-in"; // Añadida una pequeña animación si la tienes en tailwind
        form.reset();

        // --- AUTO-BORRADO a los 5 segundos---
        setTimeout(() => {
          status!.classList.replace("block", "hidden");
        }, 5000);
        // ---------------------------------
      } else {
        throw new Error();
      }
    } catch (e) {
      status!.textContent = "✕ Error al enviar el mensaje";
      status!.className =
        "p-3 rounded-xl text-[10px] font-bold uppercase tracking-widest text-center bg-red-500/10 text-red-500 block";

      // mostramos los errores
    } finally {
      btn.disabled = false;
      btn.innerHTML = originalText;
    }
  });
</script>
