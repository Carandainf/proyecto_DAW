---
/**
 * @file TeamBento.astro (Versión Responsive Optimizada)
 * @description Presentación del equipo con contenedores de imagen adaptativos
 * para evitar recortes en resoluciones intermedias (1024px - 1366px).
 */

const team = [
  {
    name: "Alejandro Ruiz",
    role: "Especialista CAD/CAM & Fresado Digital",
    bio: "Experto en el flujo digital completo, transforma escaneos intraorales en estructuras de circonio con precisión micrométrica.",
    image: "/team/alejandro.webp",
    gridSpan: "md:col-span-2",
  },
  {
    name: "Carmen García",
    role: "Maestra Ceramista & Estética",
    bio: "Domina la estratificación de cerámica sobre disilicato, garantizando sonrisas naturales y personalizadas.",
    image: "/team/carmen.webp",
  },
  {
    name: "Manuel Jiménez",
    role: "Técnico Senior Removible",
    bio: "Especialista en casos complejos de edentulismo y modernos sistemas de anclaje sobre implantes.",
    image: "/team/manuel.webp",
  },
  {
    name: "Rocío Morales",
    role: "Diseño Digital & Férulas 3D",
    bio: "Planifica rehabilitaciones complejas mediante software exocad e impresión 3D de alta resolución.",
    image: "/team/rocio.webp",
    gridSpan: "md:col-span-2",
  },
  {
    name: "Javier López",
    role: "Experto en Modelos Maestros",
    bio: "Asegura la fidelidad absoluta de los modelos maestros y la preparación crítica de troqueles.",
    image: "/team/javier.webp",
  },
  {
    name: "María Flores",
    role: "Dirección de Administración",
    bio: "Gestiona la logística de envíos y asegura una comunicación fluida con cada clínica dental.",
    image: "/team/maria.webp",
  },
];
---

<section id="equipo" class="scroll-mt-24 mt-20 md:mt-28 w-full">
  <header class="max-w-3xl mb-10 sm:mb-16">
    <div class="flex gap-3 items-center mb-4">
      <div class="w-1.5 h-6 bg-dent-accent rounded-full"></div>
      <h2
        class="text-3xl sm:text-4xl md:text-5xl font-black text-dent-dark italic tracking-tighter leading-none"
      >
        Artesanos de la <br /><span class="text-dent-accent">Tecnología</span> Dental
      </h2>
    </div>
    <p
      class="text-slate-500 mt-6 text-sm md:text-base lg:text-lg font-medium italic leading-relaxed"
    >
      En DentalLab, fusionamos la precisión digital con la maestría artesanal. Nuestro equipo
      malagueño está comprometido con la excelencia en cada prótesis.
    </p>
  </header>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
    {
      team.map((member) => (
        <article
          class={`bg-dent-card border border-dent-border rounded-[2.5rem] p-6 md:p-8 flex flex-col group transition-all duration-500 hover:shadow-2xl hover:shadow-cyan-950/5 relative overflow-hidden ${member.gridSpan ?? ""}`}
        >
          <div class="absolute inset-0 bg-linear-to-br from-dent-accent/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />

          <div class="flex justify-center mb-6 md:mb-8 relative z-10">
            <div class="relative w-32 h-32 md:w-40 md:h-40 lg:w-44 lg:h-44">
              <div class="absolute inset-0 bg-dent-accent rounded-full scale-0 group-hover:scale-105 transition-transform duration-500 opacity-20" />

              <div class="absolute inset-1.5 bg-white rounded-full p-1 border-4 border-slate-100 group-hover:border-dent-accent transition-colors duration-500 overflow-hidden shadow-inner flex items-center justify-center">
                <img
                  src={member.image}
                  alt={member.name}
                  class="w-full h-full object-cover rounded-full grayscale group-hover:grayscale-0 group-hover:scale-110 transition-all duration-700"
                />
              </div>

              <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 bg-dent-accent text-white px-3 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-wider text-center shadow-lg opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 delay-100 w-max max-w-[120%] z-20 leading-tight">
                {member.role}
              </div>
            </div>
          </div>

          <div class="flex-grow flex flex-col justify-end relative z-10 text-center sm:text-left">
            <h4 class="text-lg md:text-xl font-black text-dent-dark italic tracking-tighter uppercase leading-tight mb-2 group-hover:text-dent-accent transition-colors">
              {member.name}
            </h4>
            <p class="text-slate-500 text-[11px] md:text-xs font-medium leading-relaxed italic opacity-90">
              {member.bio}
            </p>
          </div>
        </article>
      ))
    }
  </div>
</section>
