---
/**
 * COMPONENTE: Navbar.astro
 * RESTAURACIÓN: Se recupera el logo "DentalLab" y el icono cuadrado.
 */
import { getUserRole } from "@/lib/auth";
const { loggedIn, role } = await getUserRole(Astro.request);

const pathname = new URL(Astro.request.url).pathname;
const isAdmin = role === "admin";
---

<header class="fixed top-4 inset-x-0 z-[100] flex justify-center px-4 pointer-events-none">
  <nav
    class="pointer-events-auto bg-slate-950/80 backdrop-blur-xl border border-white/10 px-5 sm:px-8 h-14 rounded-full flex items-center gap-6 sm:gap-10 shadow-[0_8px_32px_rgba(0,0,0,0.4)] transition-all duration-500"
  >
    <a href="/" class="flex items-center gap-3 group transition-transform active:scale-95">
      <div
        class="w-8 h-8 bg-dent-accent rounded-lg flex items-center justify-center shadow-lg shadow-cyan-500/20 group-hover:rotate-3 transition-transform"
      >
        <span class="text-dent-dark font-black text-xl">D</span>
      </div>
      <span class="text-slate-100 font-bold tracking-tighter italic text-base hidden sm:block">
        Dental<span class="text-dent-accent">Lab</span>
      </span>
    </a>

    <ul class="flex items-center gap-6">
      <li>
        <a
          href="/"
          class={`text-[10px] uppercase font-black tracking-[0.15em] transition-all hover:text-dent-accent ${pathname === "/" ? "text-dent-accent" : "text-slate-400"}`}
        >
          Inicio
        </a>
      </li>

      {
        loggedIn ? (
          <>
            <li>
              <a
                href={isAdmin ? "/dashboard/admin" : "/dashboard/cliente"}
                class={`text-[10px] uppercase font-black tracking-[0.15em] transition-all flex items-center gap-2 ${pathname.includes("/dashboard") ? (isAdmin ? "text-red-400" : "text-dent-accent") : "text-slate-400 hover:text-white"}`}
              >
                <span
                  class={`w-1.5 h-1.5 rounded-full animate-pulse ${isAdmin ? "bg-red-500" : "bg-dent-accent"}`}
                />
                {isAdmin ? "Admin" : "Panel"}
              </a>
            </li>

            <div class="w-px h-4 bg-white/10" />

            <li>
              <button class="logout-button-trigger group flex items-center gap-2 text-[10px] font-black text-slate-500 hover:text-red-400 transition-all uppercase tracking-widest cursor-pointer">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="group-hover:translate-x-0.5 transition-transform"
                >
                  <>
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                  </>
                </svg>
                <span class="hidden md:inline">Salir</span>
              </button>
            </li>
          </>
        ) : (
          <li>
            <a
              href="/#login-section"
              class="bg-dent-accent text-dent-dark px-5 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest hover:bg-white hover:scale-105 active:scale-95 transition-all shadow-lg shadow-cyan-500/20"
            >
              Entrar
            </a>
          </li>
        )
      }
    </ul>
  </nav>
</header>

<script>
  const setupLogout = () => {
    // Buscamos todos los botones con esa clase
    const logoutButtons = document.querySelectorAll(".logout-button-trigger");

    logoutButtons.forEach((btn) => {
      // Limpiamos listeners previos por si acaso
      btn.replaceWith(btn.cloneNode(true));
    });

    // Volvemos a seleccionar tras el clonado para asignar el evento limpio
    document.querySelectorAll(".logout-button-trigger").forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        e.preventDefault();
        console.log("Cerrando sesión..."); // Para que veas en consola si dispara

        try {
          const res = await fetch("/api/auth/sign-out", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({}),
            credentials: "include",
          });

          if (res.ok) {
            // Forzamos la limpieza del estado del cliente
            window.location.replace("/");
          }
        } catch (err) {
          console.error("Error al cerrar sesión:", err);
        }
      });
    });
  };
  // Ejecutar al cargar por primera vez
  setupLogout();

  // Y se vuelve a ejecutar cada vez que Astro cambia de página "sin recargar"
  document.addEventListener("astro:page-load", setupLogout);
</script>
