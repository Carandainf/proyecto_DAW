---
import "../styles/global.css";

// Añadimos darkMode a las props, por defecto es false
const { bodyClass = "p-6", title = "Proyecto DAW", darkMode = false } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>

  <body class={`${bodyClass} ${darkMode ? "dark bg-dent-bg text-dent-dark" : ""}`}>
    <slot />
  </body>
</html>
