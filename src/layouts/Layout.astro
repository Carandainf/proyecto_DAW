---
/**
 * LAYOUT PRINCIPAL
 * @description Yo del futuro: Este es el marco global.
 * Incluye la Navbar flotante y el Footer condicional.
 */
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const { title = "DentalLab - Precisión Digital", darkMode = false } = Astro.props;

// Detectamos la ruta actual
const { pathname } = Astro.url;

// Páginas donde no queremos mostrar el Footer (pero sí la Navbar)
const isLegalPage = ["/privacidad", "/aviso-legal", "/cookies"].includes(pathname);
---

<html lang="es" class={darkMode ? "dark" : ""}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
      rel="stylesheet"
    />
  </head>

  <body
    class="bg-dent-bg text-slate-900 antialiased min-h-screen flex flex-col transition-colors duration-300"
  >
    <Navbar />

    <div class="grow w-full">
      <slot />
    </div>

    {!isLegalPage && <Footer />}

    <style is:global>
      :root {
        --font-sans: "Inter", system-ui, -apple-system, sans-serif;
      }
      html {
        font-family: var(--font-sans);
        scroll-behavior: smooth;
      }
      /* Ocultar barra de scroll en navegadores modernos pero permitir scroll */
      .no-scrollbar::-webkit-scrollbar {
        display: none;
      }
      .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </body>
</html>

<script>
  const isDashboard = window.location.pathname.includes("/dashboard");

  if (isDashboard) {
    // Nota: En 2026 podrías usar WebSockets o Server-Sent Events,
    // pero mantenemos tu lógica de refresco controlada por si acaso.
    /*
    setInterval(() => {
      const isTyping = ["INPUT", "TEXTAREA"].includes(document.activeElement?.tagName || "");
      if (!isTyping) {
        window.location.reload();
      }
    }, 60000); 
    */
  }
</script>
