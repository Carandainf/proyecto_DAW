---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Recuperar Acceso | Laboratorio Dental" darkMode={true}>
  <main class="min-h-screen flex items-center justify-center p-4 bg-slate-950">
    <div class="max-w-md w-full">
      <div
        class="bg-dent-card border border-dent-border p-8 md:p-12 rounded-[2.5rem] shadow-2xl relative overflow-hidden transition-all duration-500"
      >
        <div
          class="absolute top-0 right-0 w-32 h-32 bg-dent-accent/5 rounded-full -mr-16 -mt-16 blur-3xl"
        >
        </div>

        <div id="contentManager">
          <div id="formState" class="space-y-8">
            <header class="text-center">
              <div
                class="inline-block p-3 rounded-2xl bg-dent-accent/10 border border-dent-accent/20 mb-4"
              >
                <svg
                  class="w-6 h-6 text-dent-accent"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"
                  ></path>
                </svg>
              </div>
              <h1
                class="text-3xl font-black italic tracking-tighter text-white uppercase leading-none"
              >
                Recuperar <span class="text-dent-accent">Acceso</span>
              </h1>
              <p class="text-slate-500 text-[10px] uppercase tracking-[0.2em] font-bold mt-3">
                Introduce tu email profesional
              </p>
            </header>

            <form id="forgotForm" class="space-y-6">
              <div class="group space-y-2">
                <label
                  class="block text-[10px] uppercase font-black text-slate-500 ml-1 tracking-[0.2em] group-focus-within:text-dent-accent transition-colors"
                  >Correo Electrónico</label
                >
                <input
                  name="email"
                  type="email"
                  required
                  placeholder="doctor@ejemplo.com"
                  class="w-full bg-slate-900/50 border border-white/5 text-white p-4 rounded-2xl outline-none focus:border-dent-accent/50 focus:bg-slate-900 transition-all font-medium"
                />
              </div>

              <button
                type="submit"
                id="submitBtn"
                class="group w-full bg-dent-accent text-dent-dark font-black py-4 rounded-2xl uppercase text-xs tracking-[0.3em] shadow-xl shadow-dent-accent/10 hover:scale-[1.02] active:scale-95 transition-all flex items-center justify-center gap-2"
              >
                <span>Enviar Instrucciones</span>
                <svg
                  class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </button>
            </form>

            <div class="text-center">
              <a
                href="/"
                class="text-[10px] font-bold text-slate-500 hover:text-white transition-colors uppercase tracking-widest"
              >
                ← Volver al login
              </a>
            </div>
          </div>

          <div
            id="successState"
            class="hidden flex flex-col items-center text-center py-6 animate-fade-in"
          >
            <div
              class="w-20 h-20 bg-status-success/10 rounded-full flex items-center justify-center border border-status-success/20 mb-8"
            >
              <svg
                class="w-10 h-10 text-status-success"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="3"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>

            <h2 class="text-2xl font-black italic text-white uppercase tracking-tighter">
              ¡Correo Enviado!
            </h2>
            <p class="text-slate-400 text-xs font-medium mt-4 leading-relaxed">
              Si tu dirección está en nuestra base de datos, recibirás un enlace para configurar tu
              nueva contraseña en unos instantes.
            </p>

            <div class="w-full h-px bg-white/5 my-8"></div>

            <a
              href="/"
              class="w-full bg-white text-slate-950 font-black py-4 rounded-2xl uppercase text-[10px] tracking-[0.3em] shadow-xl hover:scale-[1.02] active:scale-95 transition-all"
            >
              Volver al Inicio
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  const formState = document.getElementById("formState");
  const successState = document.getElementById("successState");
  const form = document.getElementById("forgotForm") as HTMLFormElement;
  const btn = document.getElementById("submitBtn") as HTMLButtonElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Bloqueo de botón
    btn.disabled = true;
    btn.innerHTML = `<span class="animate-pulse">Procesando...</span>`;

    const email = new FormData(form).get("email");

    try {
      const res = await fetch("/api/auth/forgot-password", {
        method: "POST",
        body: JSON.stringify({ email }),
        headers: { "Content-Type": "application/json" },
      });

      // Independientemente de si el mail existe o no (por seguridad)
      // mostramos el estado de éxito para dar feedback al usuario
      if (res.ok) {
        if (formState) formState.style.display = "none";
        if (successState) {
          successState.classList.remove("hidden");
          successState.style.display = "flex";
        }
      }
    } catch (err) {
      alert("Error de conexión con el laboratorio");
      btn.disabled = false;
      btn.innerText = "Enviar Instrucciones";
    }
  });
</script>
