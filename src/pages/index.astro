---
import Layout from "../layouts/Layout.astro";
import LoginForm from "../components/LoginForm.astro";
import { protectRoute } from "@/lib/auth";

const auth = await protectRoute(Astro.request);
if (auth.user) {
  return Astro.redirect(auth.user.role === "admin" ? "/dashboard/admin" : "/dashboard/cliente");
}
---

<Layout title="Laboratorio Dental - Acceso">
  <main class="min-h-screen p-4 md:p-8 flex items-center justify-center">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-6xl w-full">
      <section
        class="md:col-span-2 bg-dent-card border border-dent-border rounded-3xl p-8 flex flex-col justify-end min-h-75 relative overflow-hidden shadow-sm"
      >
        <div class="absolute inset-0 bg-linear-to-br from-dent-accent/5 to-transparent"></div>
        <h1 class="text-4xl md:text-6xl font-black text-dent-dark relative z-10 leading-tight">
          Precisión Digital <br />
          <span class="text-dent-accent text-blue-600">en cada pieza.</span>
        </h1>
        <p class="text-slate-500 mt-4 max-w-md relative z-10 font-medium">
          Tu portal exclusivo para la gestión de trabajos protésicos y comunicación directa con el
          laboratorio.
        </p>
      </section>

      <section
        class="bg-dent-card border border-slate-100 rounded-3xl p-8 shadow-2xl shadow-blue-900/10 flex flex-col justify-center border-t-4 border-t-dent-accent"
      >
        <h2 class="text-2xl font-extrabold text-dent-dark mb-6 tracking-tight">Acceso Clientes</h2>
        <LoginForm />
        <div class="mt-6 text-center">
          <a
            href="#"
            class="text-xs font-bold text-slate-400 hover:text-dent-accent transition-colors uppercase tracking-widest"
          >
            ¿Has olvidado tu contraseña?
          </a>
        </div>
      </section>

      <section class="bg-slate-900 rounded-3xl p-6 flex flex-col justify-between shadow-xl">
        <h3 class="text-white font-bold text-lg">¿Aún no eres cliente?</h3>
        <p class="text-slate-300 text-xs mt-2">
          Contacta con nosotros para abrir tu cuenta profesional y empezar a enviar tus archivos
          STL.
        </p>
        <button
          class="mt-4 py-3 bg-dent-accent text-white rounded-xl text-xs font-bold hover:opacity-90 transition-all uppercase tracking-widest shadow-lg shadow-blue-600/20"
        >
          Solicitar acceso
        </button>
      </section>

      <section
        class="md:col-span-2 bg-dent-card border border-dent-border rounded-3xl p-6 flex items-center gap-6 shadow-sm"
      >
        <div class="flex gap-2">
          <div class="w-2.5 h-2.5 rounded-full bg-status-success animate-pulse"></div>
          <div class="text-[10px] text-status-success font-black uppercase tracking-widest">
            Servicio Activo
          </div>
        </div>
        <div class="h-4 w-px bg-dent-border"></div>
        <p class="text-slate-500 text-xs italic font-medium">
          Soporte técnico disponible de 09:00 a 19:00
        </p>
      </section>
    </div>
  </main>
</Layout>
