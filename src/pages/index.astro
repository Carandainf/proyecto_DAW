---
import Layout from "../layouts/Layout.astro";
import LoginForm from "../components/LoginForm.astro"; // Extraeremos tu lógica de test-auth aquí
import { protectRoute } from "@/lib/auth";

// 1. Obtenemos la respuesta completa
const auth = await protectRoute(Astro.request);

// 2. Si el usuario ya está logueado y tiene un objeto user, redirigimos
// Usamos el (?.) para que no de error si auth.user no existe
if (auth.user) {
  return Astro.redirect(auth.user.role === "admin" ? "/dashboard/admin" : "/dashboard/cliente");
}
---

<Layout title="Laboratorio Dental - Acceso Clientes">
  <main class="min-h-screen bg-dent-dark p-4 md:p-8 flex items-center justify-center">
    <div class="grid grid-cols-1 md:grid-cols-3 grid-rows-auto gap-4 max-w-6xl w-full">
      <section
        class="md:col-span-2 bg-dent-card border border-dent-border rounded-3xl p-8 flex flex-col justify-end min-h-[300px] relative overflow-hidden group"
      >
        <div class="absolute inset-0 bg-gradient-to-br from-dent-accent/10 to-transparent"></div>
        <h1 class="text-4xl md:text-6xl font-bold text-white relative z-10 leading-tight">
          Precisión Digital <br />
          <span class="text-dent-accent">en cada pieza.</span>
        </h1>
        <p class="text-slate-400 mt-4 max-w-md relative z-10">
          Tu portal exclusivo para la gestión de trabajos protésicos y comunicación directa con el
          laboratorio.
        </p>
      </section>

      <section class="bg-white rounded-3xl p-8 shadow-2xl flex flex-col justify-center">
        <h2 class="text-2xl font-bold text-slate-800 mb-6">Acceso Clientes</h2>
        <LoginForm />

        <div class="mt-6 text-center">
          <a href="#" class="text-xs text-slate-400 hover:text-dent-accent transition-colors">
            ¿Has olvidado tu contraseña?
          </a>
        </div>
      </section>

      <section
        class="bg-dent-card border border-dent-border rounded-3xl p-6 flex flex-col justify-between"
      >
        <h3 class="text-white font-medium text-sm">¿Aún no eres cliente?</h3>
        <p class="text-slate-500 text-xs mt-2">
          Contacta con nosotros para abrir tu cuenta profesional y empezar a enviar tus archivos
          STL.
        </p>
        <button
          class="mt-4 py-2 border border-dent-accent/30 text-dent-accent rounded-xl text-xs font-bold hover:bg-dent-accent/10 transition-all uppercase tracking-widest"
        >
          Solicitar acceso
        </button>
      </section>

      <section
        class="md:col-span-2 bg-dent-dark/50 border border-dent-border rounded-3xl p-6 flex items-center gap-6"
      >
        <div class="flex gap-2">
          <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
          <div class="text-[10px] text-emerald-500 font-bold uppercase tracking-tighter">
            Servicio Activo
          </div>
        </div>
        <div class="h-4 w-[1px] bg-dent-border"></div>
        <p class="text-slate-500 text-xs italic">Soporte técnico disponible de 09:00 a 19:00</p>
      </section>
    </div>
  </main>
</Layout>
