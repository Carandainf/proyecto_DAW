---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 - Página no encontrada" darkMode={true}>
  <main class="min-h-screen flex items-center justify-center px-4 py-16">
    <div class="text-center w-full max-w-6xl mx-auto">
      <!-- BLOQUE 404 -->
      <div class="mb-20 relative flex items-center justify-center">
        <!-- 404 gigante -->
        <div
          class="text-[180px] sm:text-[260px] md:text-[360px] lg:text-[500px]
                 font-black text-white/5 select-none italic leading-none rotate-[-5deg] absolute z-0 animate-float-slow"
        >
          404
        </div>

        <!-- ICONO -->
        <div class="relative z-10 flex items-center justify-center py-20 animate-float">
          <div
            class="absolute w-60 h-60 bg-dent-accent/20 rounded-full blur-3xl animate-pulse-soft"
          >
          </div>

          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-32 h-32 md:w-40 md:h-40 text-dent-accent relative"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.2"
          >
            <path d="M10 21v-6.5a3.5 3.5 0 0 0-7 0V21h7Z"></path>
            <path d="M21 21v-6.5a3.5 3.5 0 0 0-7 0V21h7Z"></path>
            <path d="M7 14.5a3.5 3.5 0 0 1 10 0V21H7v-6.5Z"></path>
            <path d="M12 5a3 3 0 1 0 0 6 3 3 0 1 0 0-6Z"></path>
          </svg>
        </div>
      </div>

      <!-- TITULO -->
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-10 italic leading-tight">
        ¡Vaya! Esta pieza <span class="text-dent-accent">no encaja</span>
      </h1>

      <!-- TEXTO -->
      <p class="text-slate-400 mb-16 max-w-xl mx-auto text-lg md:text-xl leading-relaxed">
        La página que buscas no existe o ha sido movida. Es posible que el enlace esté roto o haya
        un error en la dirección.
      </p>

      <!-- BOTONES -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mt-4">
        <a
          href="/"
          class="bg-dent-accent text-dent-dark font-medium py-2 px-6 rounded-full
                 hover:brightness-110 transition shadow-md text-sm"
        >
          Volver al Inicio
        </a>

        <button
          onclick="history.back()"
          class="border border-slate-700 text-slate-300 font-medium py-2 px-6 rounded-full
                 hover:bg-slate-800 transition text-sm"
        >
          Ir atrás
        </button>
      </div>
    </div>
  </main>
</Layout>

<style>
  /* Flotación suave del icono */
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }

  /* Flotación más lenta del 404 */
  .animate-float-slow {
    animation: float 8s ease-in-out infinite;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-15px);
    }
  }

  /* Glow pulsante */
  .animate-pulse-soft {
    animation: pulse-soft 3s infinite ease-in-out;
  }

  @keyframes pulse-soft {
    0%,
    100% {
      opacity: 0.6;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.1);
    }
  }

  svg {
    filter: drop-shadow(0 0 25px rgba(251, 191, 36, 0.5));
  }
</style>
