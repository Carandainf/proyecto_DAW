---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <div
        class="grid grid-flow-dense gap-4 auto-rows-min max-w-[1500px] mx-auto p-4
            sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
    >
        <!-- Register: 2 columnas, altura variable -->
        <div
            class="bg-blue-200 p-4 rounded shadow-md hover:scale-105 transition-transform col-span-2 break-inside-avoid"
        >
            <h2 class="text-xl font-semibold mb-2">Register</h2>
            <form id="registerForm" class="space-y-2">
                <input
                    name="name"
                    placeholder="Name"
                    class="w-full p-2 border rounded"
                    required
                />
                <input
                    name="email"
                    type="email"
                    placeholder="Email"
                    class="w-full p-2 border rounded"
                    required
                />
                <input
                    name="password"
                    type="password"
                    placeholder="Password"
                    class="w-full p-2 border rounded"
                    required
                />
                <button
                    type="submit"
                    class="bg-blue-500 text-white w-full py-2 rounded hover:bg-blue-600"
                    >Register</button
                >
            </form>
        </div>

        <!-- Login: 1 columna, más alto -->
        <div
            class="bg-green-200 p-4 rounded shadow-md hover:scale-105 transition-transform col-span-1 row-span-2 break-inside-avoid"
        >
            <h2 class="text-xl font-semibold mb-2">Login</h2>
            <form id="loginForm" class="space-y-2">
                <input
                    name="email"
                    type="email"
                    placeholder="Email"
                    class="w-full p-2 border rounded"
                    required
                />
                <input
                    name="password"
                    type="password"
                    placeholder="Password"
                    class="w-full p-2 border rounded"
                    required
                />
                <button
                    type="submit"
                    class="bg-green-500 text-white w-full py-2 rounded hover:bg-green-600"
                    >Login</button
                >
            </form>
        </div>

        <!-- Session: 1 columna -->
        <div
            class="bg-yellow-200 p-4 rounded shadow-md hover:scale-105 transition-transform col-span-1 break-inside-avoid"
        >
            <h2 class="text-xl font-semibold mb-2">Session</h2>
            <button
                id="sessionBtn"
                class="bg-yellow-500 text-white w-full py-2 rounded hover:bg-yellow-600"
                >Get Session</button
            >
        </div>

        <!-- Logout: 2 columnas, altura variable -->
        <div
            class="bg-red-200 p-4 rounded shadow-md hover:scale-105 transition-transform col-span-2 break-inside-avoid"
        >
            <h2 class="text-xl font-semibold mb-2">Logout</h2>
            <button
                id="logoutBtn"
                class="bg-red-500 text-white w-full py-2 rounded hover:bg-red-600"
                >Logout</button
            >
        </div>

        <!-- Output: 4 columnas, altura grande -->
        <div
            class="bg-gray-800 text-white p-4 rounded shadow-md overflow-auto col-span-4 break-inside-avoid"
        >
            <h2 class="text-xl font-semibold mb-2">Output</h2>
            <pre id="output" class="whitespace-pre-wrap max-h-[400px]"></pre>
        </div>
    </div>
</Layout>

<!-- Código cliente TS/JS -->
<script type="module">
    const output = document.getElementById("output");
    const registerForm = document.getElementById("registerForm");
    const loginForm = document.getElementById("loginForm");
    const sessionBtn = document.getElementById("sessionBtn");
    const logoutBtn = document.getElementById("logoutBtn");

    async function handleFetch(url, options = {}) {
        const res = await fetch(url, {
            headers: { "Content-Type": "application/json" },
            credentials: "include",
            ...options,
        });
        const data = await res.json();
        if (output) output.textContent = JSON.stringify(data, null, 2);
    }

    registerForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!registerForm) return;

        const form = new FormData(registerForm);
        const bodyJson = JSON.stringify(Object.fromEntries(form.entries()));

        console.log("Registro - body a enviar:", bodyJson); // <-- Aquí ves qué se construye

        await handleFetch("/api/auth-test/register", {
            method: "POST",
            body: bodyJson,
        });
    });

    loginForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!loginForm) return;
        const form = new FormData(loginForm);

        const loginData = {
            email: form.get("email"),
            password: form.get("password"),
        };

        await handleFetch("/api/auth-test/login", {
            method: "POST",
            body: JSON.stringify(loginData),
        });
    });

    sessionBtn?.addEventListener("click", async () => {
        await handleFetch("/api/auth-test/session");
    });

    logoutBtn?.addEventListener("click", async () => {
        await handleFetch("/api/auth-test/logout", { method: "POST" });
    });
</script>
