---
/**
 * PÁGINA: CONFIGURAR NUEVA CONTRASEÑA
 * @description Esta página requiere un token válido en la URL.
 * Si el token expira, Better-Auth devolverá un error y el script lo mostrará.
 */
import Layout from "@/layouts/Layout.astro";

// Obtenemos el token de la URL (ej: /reset-password?token=...)
const token = Astro.url.searchParams.get("token");

// Si no hay token, mandamos al usuario al inicio por seguridad
if (!token) {
  return Astro.redirect("/");
}
---

<Layout title="Nueva Contraseña | Laboratorio Dental" darkMode={true}>
  <main
    class="min-h-screen flex items-center justify-center p-4 bg-slate-950 selection:bg-dent-accent selection:text-dent-dark"
  >
    <div class="max-w-md w-full">
      <div
        class="bg-dent-card border border-white/5 p-8 md:p-12 rounded-[2.5rem] shadow-[0_0_50px_-12px_rgba(0,0,0,0.5)] relative overflow-hidden transition-all duration-500"
      >
        <div
          class="absolute top-0 right-0 w-32 h-32 bg-dent-accent/10 rounded-full -mr-16 -mt-16 blur-3xl"
        >
        </div>

        <div id="contentManager">
          <div id="formState">
            <header class="mb-10 text-center">
              <div
                class="inline-block p-4 rounded-2xl bg-dent-accent/5 border border-dent-accent/20 mb-6 shadow-inner text-dent-accent"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3-3.5 3.5z"
                  ></path></svg
                >
              </div>
              <h1
                class="text-3xl font-black italic tracking-tighter text-white uppercase leading-none"
              >
                Nueva <span class="text-dent-accent">Contraseña</span>
              </h1>
              <p class="text-slate-500 text-[10px] uppercase tracking-[0.2em] font-black mt-4">
                Configura tu acceso de seguridad
              </p>
            </header>

            <form id="resetForm" class="space-y-6">
              <input type="hidden" name="token" value={token} />

              <div class="group space-y-2">
                <label
                  class="block text-[10px] uppercase font-black text-slate-500 ml-1 tracking-widest group-focus-within:text-dent-accent transition-colors"
                >
                  Contraseña Nueva
                </label>
                <input
                  name="password"
                  type="password"
                  id="password"
                  required
                  minlength="8"
                  placeholder="••••••••"
                  class="w-full bg-slate-900/40 border border-white/10 text-white p-4 rounded-2xl outline-none focus:border-dent-accent/50 focus:ring-4 focus:ring-dent-accent/5 transition-all font-medium placeholder:text-slate-700"
                />
              </div>

              <div class="group space-y-2">
                <label
                  class="block text-[10px] uppercase font-black text-slate-500 ml-1 tracking-widest group-focus-within:text-dent-accent transition-colors"
                >
                  Confirmar Contraseña
                </label>
                <input
                  name="confirmPassword"
                  type="password"
                  id="confirmPassword"
                  required
                  placeholder="••••••••"
                  class="w-full bg-slate-900/40 border border-white/10 text-white p-4 rounded-2xl outline-none focus:border-dent-accent/50 focus:ring-4 focus:ring-dent-accent/5 transition-all font-medium placeholder:text-slate-700"
                />
              </div>

              <button
                type="submit"
                id="submitBtn"
                class="group w-full bg-dent-accent text-dent-dark font-black py-4 rounded-2xl uppercase text-xs tracking-[0.3em] shadow-xl shadow-dent-accent/10 hover:shadow-dent-accent/20 hover:scale-[1.02] active:scale-95 transition-all mt-4 flex items-center justify-center gap-3"
              >
                <span>Guardar y Acceder</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="group-hover:translate-x-1 transition-transform"
                  ><path d="M5 12h14m-7-7 7 7-7 7"></path></svg
                >
              </button>

              <p
                id="message"
                class="hidden text-center text-[10px] font-black uppercase mt-6 tracking-widest px-4 py-3 rounded-xl border border-white/5 bg-white/5 shadow-inner"
              >
              </p>
            </form>
          </div>

          <div id="successBlock" class="hidden text-center space-y-8 py-6 animate-fade-in">
            <div class="flex justify-center">
              <div
                class="w-24 h-24 bg-status-success/10 rounded-full flex items-center justify-center border border-status-success/20 shadow-[0_0_30px_-5px_rgba(16,185,129,0.2)]"
              >
                <svg
                  class="w-12 h-12 text-status-success"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
            </div>

            <div>
              <h2 class="text-3xl font-black italic text-white uppercase tracking-tighter">
                ¡Acceso <span class="text-dent-accent">Restaurado</span>!
              </h2>
              <p class="text-slate-500 text-[10px] uppercase tracking-[0.2em] font-black mt-3">
                Tu nueva contraseña ha sido configurada
              </p>
            </div>

            <div class="w-full h-px bg-white/5 my-8"></div>

            <a
              href="/"
              class="block w-full bg-white text-slate-950 font-black py-4 rounded-2xl uppercase text-[10px] tracking-[0.3em] shadow-xl hover:bg-slate-100 hover:scale-[1.02] active:scale-95 transition-all"
            >
              Iniciar Sesión Ahora
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .animate-fade-in {
    animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(20px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
</style>

<script>
  import { authClient } from "@/lib/auth-client";

  const form = document.getElementById("resetForm") as HTMLFormElement;
  const formState = document.getElementById("formState");
  const successBlock = document.getElementById("successBlock") as HTMLDivElement;
  const btn = document.getElementById("submitBtn") as HTMLButtonElement;
  const message = document.getElementById("message");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const password = formData.get("password") as string;
    const confirmPassword = formData.get("confirmPassword") as string;
    const token = formData.get("token") as string;

    // 1. Validación local (UX rápida)
    if (password !== confirmPassword) {
      showMessage("Las contraseñas no coinciden", "text-red-400 border-red-500/20 bg-red-500/5");
      return;
    }

    if (password.length < 8) {
      showMessage("Mínimo 8 caracteres", "text-amber-400 border-amber-500/20 bg-amber-500/5");
      return;
    }

    // 2. Estado de carga
    btn.disabled = true;
    const originalContent = btn.innerHTML;
    btn.innerHTML = `<span class="animate-pulse">CONFIGURANDO...</span>`;
    message?.classList.add("hidden");

    try {
      // 3. Better Auth Call
      const { error } = await authClient.resetPassword({
        newPassword: password,
        token: token,
      });

      if (error) {
        showMessage(
          error.message || "Enlace caducado",
          "text-red-400 border-red-500/20 bg-red-500/5"
        );
        btn.disabled = false;
        btn.innerHTML = originalContent;
      } else {
        // 4. ÉXITO TOTAL
        if (formState) formState.style.display = "none";
        if (successBlock) {
          successBlock.classList.remove("hidden");
          successBlock.style.display = "block";
        }
      }
    } catch (err) {
      showMessage("Error de conexión", "text-red-400 border-red-500/20 bg-red-500/5");
      btn.disabled = false;
      btn.innerHTML = originalContent;
    }
  });

  function showMessage(text: string, styleClasses: string) {
    if (message) {
      message.textContent = text;
      message.className = `text-center text-[10px] font-black uppercase mt-6 tracking-widest px-4 py-3 rounded-xl border ${styleClasses}`;
      message.classList.remove("hidden");
    }
  }
</script>
