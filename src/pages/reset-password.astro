---
import Layout from "@/layouts/Layout.astro";

// Obtenemos el token de la URL (ej: /reset-password?token=...)
const token = Astro.url.searchParams.get("token");

// Si no hay token, redirigir al index
if (!token) {
  return Astro.redirect("/");
}
---

<Layout title="Configurar Contraseña | Laboratorio Dental" darkMode={true}>
  <main class="min-h-screen flex items-center justify-center p-4 bg-slate-950">
    <div class="max-w-md w-full">
      <div
        class="bg-dent-card border border-dent-border p-8 md:p-12 rounded-[2.5rem] shadow-2xl relative overflow-hidden"
      >
        <div
          class="absolute top-0 right-0 w-32 h-32 bg-dent-accent/5 rounded-full -mr-16 -mt-16 blur-3xl"
        >
        </div>

        <header class="mb-10 text-center">
          <h1 class="text-3xl font-black italic tracking-tighter text-white">
            Nueva <span class="text-dent-accent">Contraseña</span>
          </h1>
          <p class="text-slate-500 text-[10px] uppercase tracking-[0.2em] font-bold mt-2">
            Configura tu acceso de seguridad
          </p>
        </header>

        <form id="resetForm" class="space-y-6">
          <input type="hidden" name="token" value={token} />

          <div class="space-y-2">
            <label
              class="block text-[10px] uppercase font-black text-slate-500 ml-1 tracking-widest"
              >Contraseña Nueva</label
            >
            <input
              name="password"
              type="password"
              id="password"
              required
              minlength="8"
              placeholder="••••••••"
              class="w-full bg-slate-900/50 border border-white/5 text-white p-4 rounded-2xl outline-none focus:border-dent-accent/50 transition-all font-medium"
            />
          </div>

          <div class="space-y-2">
            <label
              class="block text-[10px] uppercase font-black text-slate-500 ml-1 tracking-widest"
              >Confirmar Contraseña</label
            >
            <input
              name="confirmPassword"
              type="password"
              id="confirmPassword"
              required
              placeholder="••••••••"
              class="w-full bg-slate-900/50 border border-white/5 text-white p-4 rounded-2xl outline-none focus:border-dent-accent/50 transition-all font-medium"
            />
          </div>

          <button
            type="submit"
            id="submitBtn"
            class="w-full bg-dent-accent text-dent-dark font-black py-4 rounded-2xl uppercase text-xs tracking-[0.3em] shadow-xl shadow-dent-accent/10 hover:scale-[1.02] active:scale-95 transition-all mt-4"
          >
            Guardar y Acceder
          </button>

          <p
            id="message"
            class="hidden text-center text-[10px] font-black uppercase mt-6 tracking-widest px-4 py-3 rounded-xl bg-white/5"
          >
          </p>
        </form>

        <div id="successBlock" class="hidden text-center space-y-8 py-4">
          <div class="flex justify-center">
            <div
              class="w-20 h-20 bg-dent-accent/10 rounded-full flex items-center justify-center border border-dent-accent/20"
            >
              <svg
                class="w-10 h-10 text-dent-accent"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="3"
                  d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
          </div>

          <div>
            <h2 class="text-2xl font-black italic text-white uppercase tracking-tighter">
              ¡Contraseña Guardada!
            </h2>
            <p class="text-slate-500 text-[10px] uppercase tracking-[0.2em] font-bold mt-2">
              Tu acceso ha sido configurado con éxito
            </p>
          </div>

          <a
            href="/"
            class="block w-full bg-white text-slate-950 font-black py-4 rounded-2xl uppercase text-xs tracking-[0.3em] shadow-xl hover:bg-dent-accent hover:scale-[1.02] active:scale-95 transition-all"
          >
            Volver a la Página Principal
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { authClient } from "@/lib/auth-client";

  const form = document.getElementById("resetForm") as HTMLFormElement;
  const successBlock = document.getElementById("successBlock") as HTMLDivElement;
  const btn = document.getElementById("submitBtn") as HTMLButtonElement;
  const message = document.getElementById("message");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const password = formData.get("password") as string;
    const confirmPassword = formData.get("confirmPassword") as string;
    const token = formData.get("token") as string;

    // 1. Validación de coincidencia
    if (password !== confirmPassword) {
      showMessage("Las contraseñas no coinciden", "text-red-500");
      return;
    }

    // 2. Estado de carga
    btn.disabled = true;
    const originalBtnText = btn.innerText;
    btn.innerText = "PROCESANDO...";
    message?.classList.add("hidden");

    try {
      console.log("Enviando petición de reset...");

      // 3. Llamada a Better Auth
      // IMPORTANTE: Añadimos await y desestructuramos el resultado
      const result = await authClient.resetPassword({
        newPassword: password,
        token: token,
      });

      console.log("Resultado de Better-Auth:", result);

      if (result.error) {
        console.error("Error devuelto por la API:", result.error);
        showMessage(result.error.message || "Token inválido o expirado", "text-red-400");
        btn.disabled = false;
        btn.innerText = originalBtnText;
      } else {
        console.log("¡Éxito! Ocultando formulario...");
        // 4. ÉXITO: Forzamos el cambio de visibilidad
        if (form) form.style.display = "none";
        if (successBlock) {
          successBlock.classList.remove("hidden");
          successBlock.style.display = "block";
        }
        // Desplazar hacia arriba para que el usuario vea el mensaje de éxito
        window.scrollTo({ top: 0, behavior: "smooth" });
      }
    } catch (err) {
      console.error("Error crítico en el bloque catch:", err);
      showMessage("Error inesperado en la comunicación", "text-red-400");
      btn.disabled = false;
      btn.innerText = originalBtnText;
    }
  });

  function showMessage(text: string, colorClass: string) {
    if (message) {
      message.textContent = text;
      message.className = `text-center text-[10px] font-black uppercase mt-6 tracking-widest px-4 py-3 rounded-xl bg-white/5 ${colorClass}`;
      message.classList.remove("hidden");
    }
  }
</script>
