---
import Layout from "@/layouts/Layout.astro";
---

<Layout bodyClass="bg-orange-50 min-h-screen p-4 font-sans">
    <div
        class="max-w-[1500px] mx-auto grid gap-4
                grid-cols-1 sm:grid-cols-3 md:grid-cols-6
                auto-rows-auto"
    >
        <!-- Hero / Principal -->
        <div
            class="col-span-1 sm:col-span-2 md:col-span-4 row-span-1 border border-gray-600 rounded-lg p-6 bg-white shadow-md"
        >
            <h1 class="text-2xl font-bold mb-4">Auth Test Panel</h1>

            <!-- REGISTER FORM -->
            <form id="registerForm" class="space-y-4">
                <input
                    name="name"
                    placeholder="Nombre"
                    class="border p-2 w-full rounded"
                    required
                />
                <input
                    name="email"
                    type="email"
                    placeholder="Email"
                    class="border p-2 w-full rounded"
                    required
                />
                <input
                    name="password"
                    type="password"
                    placeholder="Contraseña"
                    class="border p-2 w-full rounded"
                    required
                />
                <button
                    type="submit"
                    class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 transition"
                    >Registrar</button
                >
            </form>

            <!-- LOGIN FORM -->
            <form id="loginForm" class="space-y-4 mt-6">
                <input
                    name="email"
                    type="email"
                    placeholder="Email"
                    class="border p-2 w-full rounded"
                    required
                />
                <input
                    name="password"
                    type="password"
                    placeholder="Contraseña"
                    class="border p-2 w-full rounded"
                    required
                />
                <button
                    type="submit"
                    class="bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600 transition"
                    >Login</button
                >
            </form>

            <!-- ACTION BUTTONS -->
            <div class="flex flex-wrap gap-4 mt-6">
                <button
                    id="sessionBtn"
                    class="bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition flex-1 sm:flex-auto"
                    >Get Session</button
                >
                <button
                    id="logoutBtn"
                    class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 transition flex-1 sm:flex-auto"
                    >Logout</button
                >
            </div>

            <pre
                id="output"
                class="bg-black text-white p-4 mt-4 rounded whitespace-pre-wrap break-words">
            </pre>
        </div>

        <!-- Aside2 -->
        <div
            class="col-span-1 sm:col-span-1 md:col-span-2 row-span-1 border border-gray-600 rounded-lg p-4 bg-white shadow-md"
        >
            <h2 class="font-bold text-lg mb-2">Info / Ayuda</h2>
            <p class="text-sm text-gray-700">
                Panel lateral donde puedes mostrar información adicional, tips o
                logs.
            </p>
        </div>

        <!-- Aside3 -->
        <div
            class="col-span-1 sm:col-span-1 md:col-span-2 border border-gray-600 rounded-lg p-4 bg-white shadow-md"
        >
            <h3 class="font-bold mb-2">Extra 1</h3>
            <p class="text-sm text-gray-700">Contenido adicional</p>
        </div>

        <!-- Aside4 -->
        <div
            class="col-span-1 sm:col-span-1 md:col-span-2 border border-gray-600 rounded-lg p-4 bg-white shadow-md"
        >
            <h3 class="font-bold mb-2">Extra 2</h3>
            <p class="text-sm text-gray-700">Contenido adicional</p>
        </div>

        <!-- Aside5 -->
        <div
            class="col-span-1 sm:col-span-1 md:col-span-2 border border-gray-600 rounded-lg p-4 bg-white shadow-md"
        >
            <h3 class="font-bold mb-2">Extra 3</h3>
            <p class="text-sm text-gray-700">Contenido adicional</p>
        </div>
    </div>
</Layout>

<script type="module">
    const output = document.getElementById("output");
    const registerForm = document.getElementById("registerForm");
    const loginForm = document.getElementById("loginForm");
    const sessionBtn = document.getElementById("sessionBtn");
    const logoutBtn = document.getElementById("logoutBtn");

    async function handleFetch(url, options = {}) {
        const res = await fetch(url, {
            headers: { "Content-Type": "application/json" },
            credentials: "include",
            ...options,
        });
        const data = await res.json();
        if (output) output.textContent = JSON.stringify(data, null, 2);
    }

    registerForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!registerForm) return;
        const form = new FormData(registerForm);
        const registerData = {
            name: form.get("name"),
            email: form.get("email"),
            password: form.get("password"),
        };
        await handleFetch("/api/test/register", {
            method: "POST",
            body: JSON.stringify(registerData),
        });
    });

    loginForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!loginForm) return;
        const form = new FormData(loginForm);
        const loginData = {
            email: form.get("email"),
            password: form.get("password"),
        };
        await handleFetch("/api/test/login", {
            method: "POST",
            body: JSON.stringify(loginData),
        });
    });

    sessionBtn?.addEventListener("click", async () => {
        await handleFetch("/api/test/session");
    });

    logoutBtn?.addEventListener("click", async () => {
        await handleFetch("/api/test/logout", { method: "POST" });
    });
</script>
