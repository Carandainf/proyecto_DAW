---
// para que funcione en local
const BASE_URL = "http://localhost:4321";

const register = async () => {
    const res = await fetch(`${BASE_URL}/api/test/register`, {
        method: "POST",
    });
    return await res.json();
};

const login = async () => {
    const res = await fetch(`${BASE_URL}/api/test/login`, {
        method: "POST",
    });
    return await res.json();
};

const session = async () => {
    const res = await fetch(`${BASE_URL}/api/test/session`);
    return await res.json();
};

let registerResult = null;
let loginResult = null;
let sessionResult = null;

try {
    registerResult = await register();
    loginResult = await login();
    sessionResult = await session();
} catch (error) {
    console.error(error);
}
---

<h1>Test Better-Auth</h1>

<h2>Register</h2>
<pre>{JSON.stringify(registerResult, null, 2)}</pre>

<h2>Login</h2>
<pre>{JSON.stringify(loginResult, null, 2)}</pre>

<h2>Session</h2>
<pre>{JSON.stringify(sessionResult, null, 2)}</pre>
