---
import Layout from "@/layouts/Layout.astro";
---

<Layout>
    <div
        class="grid grid-flow-dense gap-4 auto-rows-min max-w-[1500px] mx-auto p-4
            sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
    >
        <!-- Register: 2 columnas, altura variable -->
        <div
            class="bg-blue-200 p-4 rounded shadow-md hover:scale-105 transition-transform col-span-2 break-inside-avoid"
        >
            <h2 class="text-xl font-semibold mb-2">Register</h2>
            <form id="registerForm" class="space-y-2">
                <input
                    name="name"
                    placeholder="Name"
                    class="w-full p-2 border rounded"
                    required
                />
                <input
                    name="email"
                    type="email"
                    placeholder="Email"
                    class="w-full p-2 border rounded"
                    required
                />
                <input
                    name="password"
                    type="password"
                    placeholder="Password"
                    class="w-full p-2 border rounded"
                    required
                />
                <button
                    type="submit"
                    class="bg-blue-500 text-white w-full py-2 rounded hover:bg-blue-600"
                    >Register</button
                >
            </form>
        </div>

        <!-- Login: 1 columna, más alto -->
        <div
            class="bg-green-200 p-4 rounded shadow-md hover:scale-105 transition-transform col-span-1 row-span-2 break-inside-avoid"
        >
            <h2 class="text-xl font-semibold mb-2">Login</h2>
            <form id="loginForm" class="space-y-2">
                <input
                    name="email"
                    type="email"
                    placeholder="Email"
                    class="w-full p-2 border rounded"
                    required
                />
                <input
                    name="password"
                    type="password"
                    placeholder="Password"
                    class="w-full p-2 border rounded"
                    required
                />
                <button
                    type="submit"
                    class="bg-green-500 text-white w-full py-2 rounded hover:bg-green-600"
                    >Login</button
                >
            </form>
        </div>

        <!-- Session: 1 columna -->
        <div
            class="bg-yellow-200 p-4 rounded shadow-md hover:scale-105 transition-transform col-span-1 break-inside-avoid"
        >
            <h2 class="text-xl font-semibold mb-2">Session</h2>
            <button
                id="sessionBtn"
                class="bg-yellow-500 text-white w-full py-2 rounded hover:bg-yellow-600"
                >Get Session</button
            >
        </div>

        <!-- Logout: 2 columnas, altura variable -->
        <div
            class="bg-red-200 p-4 rounded shadow-md hover:scale-105 transition-transform col-span-2 break-inside-avoid"
        >
            <h2 class="text-xl font-semibold mb-2">Logout</h2>
            <button
                id="logoutBtn"
                class="bg-red-500 text-white w-full py-2 rounded hover:bg-red-600"
                >Logout</button
            >
        </div>

        <!-- Output: 4 columnas, altura grande -->
        <div
            class="bg-gray-800 text-white p-4 rounded shadow-md overflow-auto col-span-4 break-inside-avoid"
        >
            <h2 class="text-xl font-semibold mb-2">Output</h2>
            <pre id="output" class="whitespace-pre-wrap max-h-[400px]"></pre>
        </div>
    </div>
</Layout>

<script type="module">
    const output = document.getElementById("output");

    // Función genérica para enviar datos
    async function peticion(url, body) {
        try {
            const res = await fetch(url, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(body),
                credentials: "include",
            });

            // Intentamos obtener el JSON de respuesta
            const data = await res.json().catch(() => ({ status: res.status }));
            output.textContent = JSON.stringify(data, null, 2);
        } catch (err) {
            output.textContent = "Error: " + err.message;
        }
    }

    // REGISTRO
    document.getElementById("registerForm").onsubmit = async (e) => {
        e.preventDefault();
        const fd = new FormData(e.target);
        const data = Object.fromEntries(fd);

        // Better-Auth espera name, email y password
        await peticion("/api/auth/sign-up/email", {
            email: data.email,
            password: data.password,
            name: data.name || "Usuario Nuevo",
        });
    };

    // --- LOGIN CON REDIRECCIÓN POR ROL ---
    document.getElementById("loginForm").onsubmit = async (e) => {
        e.preventDefault();
        const fd = new FormData(e.target);
        const data = Object.fromEntries(fd);

        // 1. Intentamos el inicio de sesión
        await peticion("/api/auth/sign-in/email", {
            email: data.email,
            password: data.password,
        });

        // 2. Tras el login, pedimos la sesión para saber quién ha entrado
        // (Añadimos credentials: "include" para que reconozca la cookie recién creada)
        const resSession = await fetch("/api/auth/get-session", {
            credentials: "include",
        });
        const session = await resSession.json();

        // 3. SI LA SESIÓN EXISTE: Redirigimos según el rol del usuario
        if (session && session.user) {
            const role = session.user.role;

            // Si es admin va a su panel, si no, al de cliente
            window.location.href =
                role === "admin" ? "/dashboard/admin" : "/dashboard/cliente";
        }
    };

    // SESSION
    document.getElementById("sessionBtn").onclick = async () => {
        try {
            const res = await fetch("/api/auth/get-session", {
                credentials: "include",
            });
            const data = await res.json();
            output.textContent = JSON.stringify(data, null, 2);
        } catch (err) {
            output.textContent = "Error Session: " + err.message;
        }
    };

    // LOGOUT
    document.getElementById("logoutBtn").onclick = async () => {
        // En Better-Auth la ruta por defecto es sign-out
        await peticion("/api/auth/sign-out", {});
    };
</script>
