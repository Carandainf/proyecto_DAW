---
import Layout from "@/layouts/Layout.astro";
---

<Layout>
  <div class="max-w-[1200px] mx-auto p-6 md:p-12">
    <header class="mb-10 text-center">
      <h1 class="text-3xl font-bold text-slate-100 italic">
        Control de <span class="text-dent-accent">Acceso</span>
      </h1>
      <p class="text-slate-400 text-sm mt-2 font-light">Herramienta de testeo</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-dent-card border border-dent-border p-6 rounded-3xl col-span-1 md:col-span-2">
        <h2 class="text-xl font-bold text-slate-100 mb-6 uppercase">Nuevo Registro</h2>
        <form id="registerForm" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <input
            name="name"
            placeholder="Nombre completo"
            class="bg-dent-dark border border-dent-border text-slate-200 p-3 rounded-xl outline-none focus:border-dent-accent"
            required
          />
          <input
            name="email"
            type="email"
            placeholder="Email corporativo"
            class="bg-dent-dark border border-dent-border text-slate-200 p-3 rounded-xl outline-none focus:border-dent-accent"
            required
          />
          <input
            name="password"
            type="password"
            placeholder="Contraseña segura"
            class="bg-dent-dark border border-dent-border text-slate-200 p-3 rounded-xl outline-none focus:border-dent-accent"
            required
          />

          <select
            name="role"
            class="bg-dent-dark border border-dent-border text-slate-200 p-3 rounded-xl outline-none focus:border-dent-accent cursor-pointer"
          >
            <option value="user" selected>Rol: Usuario (Cliente)</option>
            <option value="admin">Rol: Administrador (Laboratorio)</option>
          </select>

          <button
            type="submit"
            class="sm:col-span-2 bg-dent-accent text-dent-dark font-bold py-3 rounded-xl uppercase text-sm tracking-widest shadow-lg shadow-cyan-900/20"
          >
            Crear Cuenta
          </button>
        </form>
      </div>

      <div class="bg-dent-card border border-dent-border p-6 rounded-3xl">
        <h2 class="text-xl font-bold text-slate-100 mb-6 uppercase">Login</h2>
        <form id="loginForm" class="space-y-4">
          <input
            name="email"
            type="email"
            placeholder="Email"
            class="w-full bg-dent-dark border border-dent-border text-slate-200 p-3 rounded-xl outline-none"
            required
          />
          <input
            name="password"
            type="password"
            placeholder="Pass"
            class="w-full bg-dent-dark border border-dent-border text-slate-200 p-3 rounded-xl outline-none"
            required
          />
          <button
            type="submit"
            class="w-full bg-status-success text-dent-dark font-bold py-3 rounded-xl uppercase text-sm"
            >Entrar</button
          >
        </form>
      </div>

      <div
        class="bg-dent-card border border-dent-border p-6 rounded-3xl md:col-span-3 grid md:grid-cols-2 gap-6"
      >
        <div>
          <h3 class="text-slate-100 font-bold mb-4 italic">Estado de Conexión</h3>
          <div class="flex gap-3">
            <button
              id="sessionBtn"
              class="flex-1 bg-dent-dark border border-dent-border text-slate-300 py-2 rounded-xl text-xs font-bold uppercase"
              >Ver Sesión</button
            >
            <button
              id="logoutBtn"
              class="flex-1 border border-red-500/30 text-red-500 py-2 rounded-xl text-xs font-bold uppercase"
              >Salir</button
            >
          </div>
        </div>
        <div class="bg-dent-dark/50 p-4 rounded-2xl">
          <pre
            id="output"
            class="text-[10px] text-cyan-100/70 font-mono overflow-auto max-h-[100px]">{"esperando..."}</pre>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const output = document.getElementById("output");

  // Definimos que 'url' es un string y 'body' es un objeto genérico
  async function peticion(url: string, body: object) {
    try {
      const res = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
        credentials: "include",
      });
      const data = await res.json().catch(() => ({ status: res.status }));
      if (output) output.textContent = JSON.stringify(data, null, 2);
    } catch (err) {
      // TypeScript quiere que aseguremos que 'err' tiene un mensaje
      if (output)
        output.textContent = "Error: " + (err instanceof Error ? err.message : "Error desconocido");
    }
  }

  // Registramos el evento de Submit
  const registerForm = document.getElementById("registerForm") as HTMLFormElement | null;
  registerForm?.addEventListener("submit", async (e: SubmitEvent) => {
    e.preventDefault();
    const target = e.target as HTMLFormElement; // Forzamos a que reconozca el formulario
    const fd = new FormData(target);
    const data = Object.fromEntries(fd);

    await peticion("/api/auth/sign-up/email", {
      email: data.email as string,
      password: data.password as string,
      name: (data.name as string) || "Usuario Nuevo",
      role: data.role as string,
    });
  });

  // Login
  const loginForm = document.getElementById("loginForm") as HTMLFormElement | null;
  loginForm?.addEventListener("submit", async (e: SubmitEvent) => {
    e.preventDefault();
    const target = e.target as HTMLFormElement;
    const fd = new FormData(target);
    const data = Object.fromEntries(fd);

    // 1. Intentamos el login
    await peticion("/api/auth/sign-in/email", {
      email: data.email as string,
      password: data.password as string,
    });

    // 2. Verificamos la sesión
    const res = await fetch("/api/auth/get-session", {
      credentials: "include",
    });
    const session = await res.json();

    // 3. Redirigimos según el rol
    if (session?.user) {
      window.location.href =
        session.user.role === "admin" ? "/dashboard/admin" : "/dashboard/cliente";
    }
  });

  // Botón Sesión
  document.getElementById("sessionBtn")?.addEventListener("click", async () => {
    const res = await fetch("/api/auth/get-session", {
      credentials: "include",
    });
    const data = await res.json();
    if (output) output.textContent = JSON.stringify(data, null, 2);
  });

  // Botón Logout
  document.getElementById("logoutBtn")?.addEventListener("click", async () => {
    await peticion("/api/auth/sign-out", {});
    location.reload();
  });
</script>
