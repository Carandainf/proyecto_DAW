---
// index.astro (Admin)
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import { protectRoute } from "@/lib/auth";

// Usamos el helper que centraliza la seguridad:
// Si no es admin, 'shouldRedirect' será true y nos dará la 'url' correcta.
const { shouldRedirect, url, user, role } = await protectRoute(
    Astro.request,
    "admin",
);

if (shouldRedirect) {
    return Astro.redirect(url);
}
---

<Layout>
    <Navbar />

    <div class="max-w-4xl mx-auto p-6">
        <h1 class="text-3xl font-bold mb-4 text-red-700">
            Dashboard Administrador
        </h1>

        <p class="mb-4">
            Bienvenido administrador,
            <strong>{user?.name}</strong>
        </p>

        <div class="bg-red-100 border border-red-300 rounded p-4">
            <p>Has entrado correctamente como administrador.</p>
            <p>Tu rol es: <strong>{role}</strong></p>
        </div>
    </div>
</Layout>
