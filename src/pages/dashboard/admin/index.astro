---
// src/pages/dashboard/admin/index.astro
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import { protectRoute } from "@/lib/auth";
import { prisma } from "@/lib/prisma";

// 1. Protección de ruta (Solo Admins)
const { shouldRedirect, url, user } = await protectRoute(Astro.request, "admin");
if (shouldRedirect) return Astro.redirect(url);

// 2. Consultas de Administración
const contactosPendientes = await prisma.contacto.findMany({
  where: { leido: false },
  orderBy: { id_contacto: "desc" },
});

const trabajosUrgentes = await prisma.archivo.findMany({
  where: { estado: "pendiente", prioridad: "urgente" },
  include: { usuario: true },
});

const actividadReciente = await prisma.mensaje.findMany({
  take: 5,
  orderBy: { fecha_envio: "desc" },
  include: { archivo: true, emisor: true },
});

const totalPendientes = await prisma.archivo.count({ where: { estado: "pendiente" } });
---

<Layout title="Panel de Control Admin" darkMode={true}>
  <Navbar />

  <main class="max-w-7xl mx-auto p-4 md:p-8">
    <header class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold italic">
          Admin <span class="text-dent-accent">Console</span>
        </h1>
        <p class="text-slate-400 text-sm">Gestión centralizada del laboratorio</p>
      </div>

      <div class="flex gap-4">
        <div class="bg-dent-card border border-dent-border px-4 py-2 rounded-2xl">
          <p class="text-[10px] uppercase tracking-widest text-slate-500 font-bold">Cola Global</p>
          <p class="text-xl font-black text-dent-accent">
            {totalPendientes}
            <span class="text-xs text-slate-400 font-normal">trabajos</span>
          </p>
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <section
        class={`bg-dent-card border-2 rounded-3xl p-6 shadow-xl transition-all ${contactosPendientes.length > 0 ? "border-amber-500/50 shadow-amber-900/10" : "border-dent-border"}`}
      >
        <div class="flex justify-between items-center mb-6">
          <h2 class="font-bold flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5 text-amber-500"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path
                d="M22 17a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9.5C2 7 4 5 6.5 5H18c2.2 0 4 1.8 4 4v1.5"
              ></path><polyline points="15 7 10 12 5 7"></polyline></svg
            >
            Contactos Web
          </h2>
          {
            contactosPendientes.length > 0 && (
              <span class="relative flex h-3 w-3">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75" />
                <span class="relative inline-flex rounded-full h-3 w-3 bg-amber-500" />
              </span>
            )
          }
        </div>

        <div class="space-y-4 max-h-[400px] overflow-y-auto pr-2">
          {
            contactosPendientes.length === 0 ? (
              <p class="text-center py-10 text-slate-500 text-xs italic">
                No hay consultas pendientes.
              </p>
            ) : (
              contactosPendientes.map((c) => (
                /* 1. Añadimos 'contacto-card' y el data-id */
                <div
                  data-id-contacto={c.id_contacto}
                  data-email={c.email}
                  class="contacto-card bg-dent-bg border border-dent-border p-3 rounded-2xl group hover:border-amber-500/30 transition-all cursor-pointer"
                >
                  <div class="flex justify-between text-[10px] mb-1">
                    <span class="font-bold text-dent-accent uppercase tracking-tighter">
                      {c.nombre}
                    </span>
                    <span class="text-slate-500">Nuevo</span>
                  </div>

                  {/* 2. Añadimos el asunto para dar más contexto al admin */}
                  <p class="text-xs font-bold text-slate-200 mb-1">{c.asunto}</p>

                  <p class="text-xs text-slate-400 line-clamp-2 italic">"{c.mensaje}"</p>
                </div>
              ))
            )
          }
        </div>
      </section>

      <section
        class="md:col-span-2 bg-dent-card border border-dent-border rounded-3xl p-6 shadow-xl"
      >
        <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 text-red-500"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><path d="m12 14 4-4 4 4"></path><path d="M3.34 19a10 10 0 1 1 17.32 0"></path></svg
          >
          Prioridad <span class="text-red-500 italic">Urgente</span>
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {
            trabajosUrgentes.length === 0 ? (
              <div class="col-span-2 bg-dent-bg/50 border border-dashed border-dent-border p-10 rounded-3xl text-center">
                <p class="text-slate-500 text-sm">No hay trabajos urgentes hoy. ¡Buen trabajo!</p>
              </div>
            ) : (
              trabajosUrgentes.map((t) => (
                <a
                  href={`/dashboard/admin/trabajo/${t.id_archivo}`}
                  class="flex items-center gap-4 p-4 bg-dent-bg border border-dent-border rounded-2xl hover:border-red-500/40 transition-all group relative overflow-hidden"
                >
                  <div class="absolute top-0 right-0 w-1 h-full bg-red-500/50" />
                  <div class="p-3 bg-red-500/10 rounded-xl text-red-500">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-6 h-6"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <>
                        <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
                        <polyline points="14 2 14 8 20 8" />
                      </>
                    </svg>
                  </div>
                  <div class="min-w-0">
                    <p class="text-sm font-bold truncate">{t.nombre_archivo}</p>
                    <p class="text-[10px] text-slate-500 font-bold uppercase tracking-wider">
                      {t.usuario.name}
                    </p>
                  </div>
                </a>
              ))
            )
          }
        </div>

        <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 gap-4">
          <button
            class="flex flex-col items-center justify-center p-4 bg-dent-bg border border-dent-border rounded-2xl hover:bg-dent-accent hover:text-dent-dark transition-all group"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-6 h-6 mb-2"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle
                cx="9"
                cy="7"
                r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path
                d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
            >
            <span class="text-[9px] font-black uppercase">Usuarios</span>
          </button>
          <button
            class="flex flex-col items-center justify-center p-4 bg-dent-bg border border-dent-border rounded-2xl hover:bg-dent-accent hover:text-dent-dark transition-all group"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-6 h-6 mb-2"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline
                points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"
              ></line></svg
            >
            <span class="text-[9px] font-black uppercase">Informes</span>
          </button>
        </div>
      </section>

      <section
        class="md:col-span-3 bg-dent-card border border-dent-border rounded-3xl p-6 shadow-xl"
      >
        <h2
          class="text-md font-bold text-white mb-6 flex items-center gap-2 uppercase tracking-widest"
        >
          <span class="w-2 h-2 bg-dent-accent rounded-full"></span>
          Conversaciones Recientes
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {
            actividadReciente.map((m) => (
              <div class="p-4 bg-dent-bg border-l-4 border-dent-accent rounded-r-2xl">
                <div class="flex justify-between items-center mb-2">
                  <span class="text-[10px] font-bold text-dent-accent truncate w-2/3">
                    {m.archivo.nombre_archivo}
                  </span>
                  <span class="text-[9px] text-slate-500 font-mono">
                    {new Date(m.fecha_envio).toLocaleTimeString([], {
                      hour: "2-digit",
                      minute: "2-digit",
                    })}
                  </span>
                </div>
                <p class="text-xs italic text-slate-200 line-clamp-2">"{m.contenido}"</p>
                <div class="mt-3 flex items-center gap-2">
                  <div class="w-5 h-5 rounded-full bg-slate-700 flex items-center justify-center text-[8px] font-bold text-white">
                    {m.emisor.name?.charAt(0)}
                  </div>
                  <span class="text-[9px] text-slate-400">
                    Enviado por <span class="text-slate-200 font-bold">{m.emisor.name}</span>
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </main>
  <div
    id="modal-contacto"
    class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-slate-950/80 backdrop-blur-sm"
  >
    <div
      class="bg-dent-card border border-dent-border w-full max-w-lg rounded-3xl p-6 shadow-2xl scale-95 transition-all"
    >
      <div class="flex justify-between items-start mb-4">
        <div>
          <h3 id="modal-nombre" class="text-xl font-bold text-dent-accent"></h3>
          <p id="modal-email" class="text-xs text-slate-500 font-mono"></p>
        </div>
        <button id="close-modal" class="text-slate-500 hover:text-white">✕</button>
      </div>

      <div class="bg-dent-bg p-4 rounded-2xl mb-6 border border-dent-border">
        <p class="text-[10px] uppercase text-slate-500 font-bold mb-1">Mensaje original:</p>
        <p id="modal-mensaje" class="text-sm italic text-slate-300"></p>
      </div>

      <form id="form-respuesta">
        <input type="hidden" id="modal-id" name="id_contacto" />
        <label class="block text-xs font-bold uppercase text-slate-500 mb-2"> Tu respuesta: </label>
        <textarea
          name="respuesta"
          required
          rows="5"
          class="w-full bg-slate-900 border border-slate-700 rounded-2xl p-4 text-sm focus:ring-1 focus:ring-dent-accent outline-none"
          placeholder="Escribe aquí la respuesta que se enviará por email..."></textarea>

        <div class="flex flex-col sm:flex-row gap-3 mt-4">
          <button
            type="submit"
            class="flex-[2] bg-dent-accent text-dent-dark font-bold py-3 rounded-2xl hover:brightness-110 transition-all"
          >
            Enviar Respuesta y Archivar
          </button>

          <button
            type="button"
            id="btn-solo-archivar"
            class="flex-1 border border-slate-700 text-slate-400 font-bold py-3 rounded-2xl hover:bg-slate-800 hover:text-white transition-all"
          >
            Solo Archivar
          </button>
        </div>
      </form>
    </div>
  </div>
</Layout>

<script>
  const modal = document.getElementById("modal-contacto");
  const formRespuesta = document.getElementById("form-respuesta") as HTMLFormElement;
  const btnArchivar = document.getElementById("btn-solo-archivar");

  // Solo archivar
  btnArchivar?.addEventListener("click", async () => {
    const id = (document.getElementById("modal-id") as HTMLInputElement).value;

    if (!id) return;

    // Feedback visual en el botón
    btnArchivar.textContent = "Archivando...";
    btnArchivar.classList.add("pointer-events-none", "opacity-50");

    try {
      const response = await fetch("/api/admin/contacto-read", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id_contacto: id }),
      });

      if (response.ok) {
        // Cerramos modal y recargamos
        location.reload();
      } else {
        alert("Error al archivar el mensaje");
        btnArchivar.textContent = "Solo Archivar";
        btnArchivar.classList.remove("pointer-events-none", "opacity-50");
      }
    } catch (err) {
      console.error("Error de red:", err);
    }
  });

  // Abrir Modal
  document.querySelectorAll(".contacto-card").forEach((card) => {
    card.addEventListener("click", () => {
      // Extraemos datos (puedes usar data-attributes en el div para más facilidad)
      const id = card.getAttribute("data-id-contacto");
      const nombre = card.querySelector(".font-bold.text-dent-accent")?.textContent;
      const mensaje = card.querySelector(".italic")?.textContent;
      const email = card.getAttribute("data-email");

      // Rellenamos el modal
      (document.getElementById("modal-id") as HTMLInputElement).value = id!;
      document.getElementById("modal-nombre")!.textContent = nombre!;
      document.getElementById("modal-mensaje")!.textContent = mensaje!;
      document.getElementById("modal-email")!.textContent = email!;

      modal?.classList.remove("hidden");
      modal?.classList.add("flex");
    });
  });

  // Cerrar Modal
  document.getElementById("close-modal")?.addEventListener("click", () => {
    modal?.classList.add("hidden");
  });

  // Enviar Respuesta
  formRespuesta?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(formRespuesta);
    const btn = formRespuesta.querySelector("button");

    btn!.disabled = true;
    btn!.textContent = "Enviando...";

    try {
      const response = await fetch("/api/admin/contacto-responder", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(Object.fromEntries(formData)),
      });

      if (response.ok) {
        location.reload();
      } else {
        alert("Error al enviar respuesta");
        btn!.disabled = false;
        btn!.textContent = "Enviar Respuesta y Archivar";
      }
    } catch (err) {
      console.error(err);
    }
  });
</script>
