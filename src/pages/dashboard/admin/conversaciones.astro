---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import { protectRoute } from "@/lib/auth";
import { prisma } from "@/lib/prisma";

const { shouldRedirect, url, user } = await protectRoute(Astro.request, "admin");
if (shouldRedirect) return Astro.redirect(url);

// Traemos los trabajos que tienen al menos un mensaje, ordenados por el último mensaje enviado
const trabajosConMensajes = await prisma.archivo.findMany({
  where: {
    mensajes: { some: {} }, // Solo archivos que tengan mensajes
  },
  include: {
    usuario: true,
    mensajes: {
      orderBy: { fecha_envio: "desc" },
      take: 1, // Para mostrar el último mensaje en la lista
    },
  },
  orderBy: {
    // Esto es un truco de Prisma para ordenar por la fecha del último mensaje
    fecha_subida: "desc",
  },
});
---

<Layout title="Centro de Mensajes | Admin" darkMode={true}>
  <Navbar />
  <main class="max-w-6xl mx-auto p-6 md:p-8">
    <div class="mb-6">
      <button
        onclick="history.back()"
        class="inline-flex items-center gap-2 text-slate-500 hover:text-dent-accent transition-colors text-sm font-medium group cursor-pointer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="group-hover:-translate-x-1 transition-transform"
          ><path d="m15 18-6-6 6-6"></path></svg
        >
        Volver al panel
      </button>
    </div>

    <header class="mb-10">
      <h1 class="text-3xl font-bold text-white italic">
        Centro de <span class="text-dent-accent">Conversaciones</span>
      </h1>
      <p class="text-slate-400 text-sm mt-1">Gestiona la comunicación técnica con los doctores.</p>
    </header>

    <div class="grid gap-4">
      {
        trabajosConMensajes.map((t) => (
          <a
            href={`/dashboard/admin/trabajo/${t.id_archivo}`}
            class="bg-dent-card border border-dent-border p-5 rounded-2xl hover:border-dent-accent/50 transition-all group flex flex-col md:flex-row md:items-center justify-between gap-4"
          >
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-dent-accent/10 flex items-center justify-center text-dent-accent font-bold">
                {t.usuario.name.substring(0, 2).toUpperCase()}
              </div>
              <div>
                <h3 class="text-slate-100 font-bold group-hover:text-dent-accent transition-colors">
                  {t.nombre_archivo}
                </h3>
                <p class="text-xs text-slate-500">
                  Doctor: <span class="text-slate-300 font-medium">{t.usuario.name}</span>
                </p>
              </div>
            </div>

            <div class="flex-1 md:px-10">
              <p class="text-sm text-slate-400 line-clamp-1 italic">
                "{t.mensajes[0]?.contenido || "Sin mensajes"}"
              </p>
              <span class="text-[10px] text-slate-600 font-mono">
                Último contacto: {new Date(t.mensajes[0]?.fecha_envio).toLocaleString()}
              </span>
            </div>

            <div class="flex items-center gap-2 text-dent-accent font-bold text-xs uppercase tracking-widest">
              Ir al chat
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="m9 18 6-6-6-6" />
              </svg>
            </div>
          </a>
        ))
      }
    </div>
  </main>
</Layout>
