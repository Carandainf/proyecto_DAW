---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import { protectRoute } from "@/lib/auth";
import { prisma } from "@/lib/prisma";

// 1. Protección de ruta (Solo Admins)
const { shouldRedirect, url, user: adminUser } = await protectRoute(Astro.request, "admin");
if (shouldRedirect) return Astro.redirect(url);

// 2. Traemos todos los trabajos
const historialCompleto = await prisma.archivo.findMany({
  include: { usuario: true },
  orderBy: { fecha_subida: "desc" },
});
---

<Layout title="Historial Global | Admin Console" darkMode={true}>
  <Navbar />
  <main class="max-w-7xl mx-auto p-6 md:p-8">
    <div class="mb-6">
      <button
        onclick="history.back()"
        class="inline-flex items-center gap-2 text-slate-500 hover:text-dent-accent transition-colors text-sm font-medium group cursor-pointer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="group-hover:-translate-x-1 transition-transform"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Volver al panel
      </button>
    </div>

    <header class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 mb-10">
      <div>
        <h1 class="text-3xl font-bold text-slate-100 italic">
          Historial <span class="text-dent-accent">Global</span>
        </h1>
        <p class="text-slate-400 text-sm">
          Registro completo de todos los trabajos del laboratorio
        </p>
      </div>

      <div class="flex flex-wrap gap-3 w-full md:w-auto">
        <div class="relative flex-1 md:w-64">
          <input
            type="text"
            id="searchBox"
            placeholder="Buscar cliente o archivo..."
            class="w-full bg-dent-card border border-dent-border rounded-xl px-4 py-2 text-sm text-white outline-none focus:ring-1 focus:ring-dent-accent transition-all"
          />
        </div>

        <select
          id="statusFilter"
          class="bg-dent-card border border-dent-border rounded-xl px-4 py-2 text-sm text-slate-300 outline-none"
        >
          <option value="all">Todos los estados</option>
          <option value="pendiente">Pendientes</option>
          <option value="en_proceso">En Proceso</option>
          <option value="completado">Completados</option>
        </select>

        <button
          id="downloadPDF"
          class="bg-dent-accent text-dent-dark px-5 py-2 rounded-xl font-bold text-xs hover:brightness-110 transition-all flex items-center gap-2 shadow-lg shadow-cyan-900/20"
        >
          EXPORTAR PDF
        </button>
      </div>
    </header>

    <div class="bg-dent-card border border-dent-border rounded-3xl overflow-hidden shadow-2xl">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse" id="historyTable">
          <thead class="bg-slate-900/50 border-b border-dent-border">
            <tr>
              <th class="p-4 text-[10px] font-black text-slate-500 uppercase tracking-widest"
                >Fecha</th
              >
              <th class="p-4 text-[10px] font-black text-slate-500 uppercase tracking-widest"
                >Cliente</th
              >
              <th class="p-4 text-[10px] font-black text-slate-500 uppercase tracking-widest"
                >Archivo</th
              >
              <th
                class="p-4 text-[10px] font-black text-slate-500 uppercase tracking-widest text-center"
                >Estado</th
              >
              <th
                class="p-4 text-[10px] font-black text-slate-500 uppercase tracking-widest text-right"
                >Acciones</th
              >
            </tr>
          </thead>
          <tbody class="divide-y divide-dent-border/30">
            {
              historialCompleto.map((t) => (
                <tr
                  class="history-row hover:bg-slate-800/20 transition-colors group"
                  data-status={t.estado}
                  data-search={`${t.nombre_archivo} ${t.usuario.name}`.toLowerCase()}
                >
                  <td class="p-4 text-xs text-slate-400 font-mono">
                    {new Date(t.fecha_subida).toLocaleDateString("es-ES")}
                  </td>
                  <td class="p-4">
                    <span class="text-xs font-bold text-dent-accent uppercase tracking-tighter">
                      {t.usuario.name}
                    </span>
                  </td>
                  <td class="p-4 text-sm text-slate-200 font-medium">{t.nombre_archivo}</td>
                  <td class="p-4 text-center">
                    <span
                      class={`px-3 py-1 rounded-full text-[9px] font-black uppercase border ${
                        t.estado === "urgente"
                          ? "bg-red-500/10 text-red-500 border-red-500/20"
                          : t.estado === "en_proceso"
                            ? "bg-cyan-500/10 text-cyan-400 border-cyan-500/20"
                            : t.estado === "completado"
                              ? "bg-emerald-500/10 text-emerald-500 border-emerald-500/20"
                              : "bg-slate-500/10 text-slate-400 border-slate-500/20"
                      }`}
                    >
                      {t.estado.replace("_", " ")}
                    </span>
                  </td>
                  <td class="p-4 text-right space-x-2">
                    <a
                      href={`/dashboard/admin/trabajo/${t.id_archivo}`}
                      class="p-2 text-slate-500 hover:text-white transition-all inline-block"
                      title="Ver detalle"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
                        <circle cx="12" cy="12" r="3" />
                      </svg>
                    </a>
                    <a
                      href={`/api/downloads/${t.id_archivo}`}
                      class="p-2 text-slate-500 hover:text-dent-accent transition-all inline-block"
                      title="Descargar"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                        <polyline points="7 10 12 15 17 10" />
                        <line x1="12" y1="15" x2="12" y2="3" />
                      </svg>
                    </a>
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </main>
</Layout>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"
></script>
<script
  is:inline
  src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"
></script>

<script define:vars={{ historialCompleto }}>
  const searchBox = document.getElementById("searchBox");
  const statusFilter = document.getElementById("statusFilter");
  const rows = document.querySelectorAll(".history-row");

  function filterTable() {
    const searchTerm = searchBox.value.toLowerCase();
    const statusTerm = statusFilter.value;

    rows.forEach((row) => {
      const rowSearchData = row.getAttribute("data-search");
      const rowStatus = row.getAttribute("data-status");
      const matchesSearch = rowSearchData.includes(searchTerm);
      const matchesStatus = statusTerm === "all" || rowStatus === statusTerm;
      row.style.display = matchesSearch && matchesStatus ? "" : "none";
    });
  }

  searchBox?.addEventListener("input", filterTable);
  statusFilter?.addEventListener("change", filterTable);

  document.getElementById("downloadPDF")?.addEventListener("click", () => {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF();
    doc.setFont("helvetica", "bold");
    doc.setFontSize(20);
    doc.setTextColor(6, 182, 212);
    doc.text("DENTAL LAB - ADMIN", 14, 20);
    doc.setFontSize(10);
    doc.setTextColor(100);
    doc.text(`Reporte generado el ${new Date().toLocaleDateString()}`, 14, 28);

    const visibleRows = Array.from(rows).filter((r) => r.style.display !== "none");
    const tableData = visibleRows.map((r) => {
      const cells = r.querySelectorAll("td");
      return [cells[0].innerText, cells[1].innerText, cells[2].innerText, cells[3].innerText];
    });

    doc.autoTable({
      startY: 35,
      head: [["Fecha", "Cliente", "Archivo", "Estado"]],
      body: tableData,
      theme: "grid",
      headStyles: { fillColor: [2, 6, 23] },
    });
    doc.save(`historial_global_${Date.now()}.pdf`);
  });
</script>
