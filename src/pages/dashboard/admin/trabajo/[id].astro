---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import { prisma } from "@/lib/prisma";
import { protectRoute } from "@/lib/auth";

const { id } = Astro.params;
const { shouldRedirect, url, user } = await protectRoute(Astro.request, "admin");
if (shouldRedirect) return Astro.redirect(url);

// Buscamos el trabajo, su dueño y su historial de mensajes
const trabajo = await prisma.archivo.findUnique({
  where: { id_archivo: Number(id) },
  include: {
    usuario: true,
    mensajes: {
      orderBy: { fecha_envio: "asc" },
      include: { emisor: true },
    },
  },
});

if (!trabajo) return Astro.redirect("/404");
---

<Layout title={`Trabajo: ${trabajo.nombre_archivo}`} darkMode={true}>
  <Navbar />

  <main class="max-w-6xl mx-auto p-4 md:p-8">
    <div class="flex flex-col md:flex-row justify-between items-start gap-6 mb-10">
      <div>
        <a
          href="/dashboard/admin"
          class="text-slate-500 hover:text-dent-accent text-sm mb-2 inline-block"
          >← Volver al panel</a
        >
        <h1 class="text-4xl font-bold italic text-white">{trabajo.nombre_archivo}</h1>
        <p class="text-slate-400">
          Cliente: <span class="text-white font-medium">{trabajo.usuario.name}</span>
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <a
          href={`/api/downloads/${trabajo.id_archivo}`}
          class="bg-white/10 hover:bg-white/20 text-white px-6 py-3 rounded-full font-bold transition-all flex items-center gap-2"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline
              points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg
          >
          Descargar Archivo
        </a>

        <select
          id="cambiar-estado"
          data-id={trabajo.id_archivo}
          class="bg-dent-accent text-dent-dark font-bold px-6 py-3 rounded-full outline-none cursor-pointer"
        >
          <option value="pendiente" selected={trabajo.estado === "pendiente"}>Pendiente</option>
          <option value="en_proceso" selected={trabajo.estado === "en_proceso"}>En Proceso</option>
          <option value="completado" selected={trabajo.estado === "completado"}>Completado</option>
        </select>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="space-y-6">
        <div class="bg-dent-card border border-dent-border p-6 rounded-3xl">
          <h2 class="text-sm font-black uppercase tracking-widest text-slate-500 mb-4">
            Detalles Técnicos
          </h2>
          <div class="space-y-3">
            <div class="flex justify-between">
              <span class="text-slate-400 text-sm">Prioridad:</span>
              <span
                class={`text-sm font-bold ${trabajo.prioridad === "urgente" ? "text-red-500" : "text-dent-accent"}`}
              >
                {trabajo.prioridad.toUpperCase()}
              </span>
            </div>
            <div class="flex justify-between">
              <span class="text-slate-400 text-sm">Recibido:</span>
              <span class="text-slate-200 text-sm">
                {
                  trabajo.fecha_subida
                    ? new Date(trabajo.fecha_subida).toLocaleDateString()
                    : "Sin fecha"
                }
              </span>
            </div>
          </div>
        </div>
      </div>

      <div
        class="lg:col-span-2 flex flex-col h-[600px] bg-dent-card border border-dent-border rounded-3xl overflow-hidden"
      >
        <div class="p-4 border-b border-dent-border bg-white/5">
          <h2 class="font-bold">Historial de Comunicación</h2>
        </div>

        <div class="flex-1 overflow-y-auto p-6 space-y-4 custom-scrollbar bg-dent-bg/30">
          {
            trabajo.mensajes.map((m) => (
              <div
                class={`flex ${user && m.id_emisor === user.id ? "justify-end" : "justify-start"}`}
              >
                <div
                  class={`max-w-[80%] p-4 rounded-2xl ${user && m.id_emisor === user.id ? "bg-dent-accent text-dent-dark rounded-tr-none" : "bg-slate-800 text-slate-200 rounded-tl-none"}`}
                >
                  <p class="text-sm">{m.contenido}</p>
                  <span class="text-[9px] opacity-70 mt-2 block text-right">
                    {m.fecha_envio ? new Date(m.fecha_envio).toLocaleTimeString() : ""}
                  </span>
                </div>
              </div>
            ))
          }
        </div>

        <form id="form-mensaje" class="p-4 bg-white/5 border-t border-dent-border flex gap-3">
          <input type="hidden" name="id_archivo" value={trabajo.id_archivo} />
          <textarea
            name="contenido"
            placeholder="Escribe un mensaje al doctor..."
            class="flex-1 bg-slate-900 border border-slate-700 rounded-2xl p-3 text-sm outline-none focus:border-dent-accent resize-none"
            rows="1"></textarea>
          <button
            class="bg-dent-accent text-dent-dark p-3 rounded-2xl hover:scale-105 transition-transform"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-6 h-6"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><line x1="22" y1="2" x2="11" y2="13"></line><polygon
                points="22 2 15 22 11 13 2 9 22 2"></polygon></svg
            >
          </button>
        </form>
      </div>
    </div>
  </main>
</Layout>

<script>
  const selectEstado = document.getElementById("cambiar-estado") as HTMLSelectElement;
  const formMensaje = document.getElementById("form-mensaje") as HTMLFormElement;

  // 1. Lógica para cambiar el estado
  selectEstado?.addEventListener("change", async (e) => {
    const nuevoEstado = (e.target as HTMLSelectElement).value;
    const id = selectEstado.getAttribute("data-id");

    const res = await fetch("/api/admin/cambiar-estado", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ id: Number(id), estado: nuevoEstado }),
    });

    if (res.ok) {
      // Opcional: podrías mostrar un check de "Guardado"
      console.log("Estado actualizado");
    }
  });

  // 2. Lógica para enviar el mensaje del chat
  formMensaje?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(formMensaje);
    const payload = Object.fromEntries(formData);

    const res = await fetch("/api/admin/enviar-mensaje", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });

    if (res.ok) {
      location.reload(); // Recargamos para que aparezca el mensaje en la lista
    } else {
      alert("Error al enviar el mensaje");
    }
  });
</script>
