---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import { prisma } from "@/lib/prisma";
import { protectRoute } from "@/lib/auth";

const { user: adminUser } = await protectRoute(Astro.request, "admin");

// Obtenemos el ID de la URL
const { id } = Astro.params;

// Buscamos al cliente
const cliente = await prisma.user.findUnique({
  where: { id: id },
});

// Si no existe, volvemos atrás
if (!cliente) {
  return Astro.redirect("/dashboard/admin/clientes");
}
---

<Layout title={`Editar ${cliente.name} | Admin`} darkMode={true}>
  <Navbar />
  <main class="max-w-4xl mx-auto p-4 md:p-8">
    <a
      href="/dashboard/admin/clientes"
      class="inline-flex items-center gap-2 text-slate-500 hover:text-dent-accent text-[10px] font-black uppercase tracking-[0.2em] mb-8 transition-colors group"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="3"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="group-hover:-translate-x-1 transition-transform"
        ><path d="m15 18-6-6 6-6"></path></svg
      >
      Volver al Listado
    </a>

    <header class="mb-12">
      <h1 class="text-4xl font-black italic tracking-tighter text-white">
        Editar <span class="text-dent-accent">Perfil</span>
      </h1>
      <p class="text-slate-500 text-xs uppercase tracking-[0.3em] mt-1 font-bold">
        ID: {cliente.id}
      </p>
    </header>

    <div
      class="bg-dent-card border border-dent-border rounded-[2.5rem] p-8 md:p-12 shadow-2xl relative overflow-hidden"
    >
      <div class="absolute top-0 right-0 p-8 opacity-5 select-none pointer-events-none">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="120"
          height="120"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          ><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"></path><path d="m15 5 4 4"
          ></path></svg
        >
      </div>

      <form id="edit-form" class="space-y-8 relative z-10">
        <input type="hidden" name="id" value={cliente.id} />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="space-y-2">
            <label class="text-[10px] uppercase tracking-[0.2em] text-slate-500 font-black ml-4"
              >Nombre Completo / Clínica</label
            >
            <input
              type="text"
              name="name"
              value={cliente.name}
              required
              class="w-full bg-slate-950 border border-white/5 rounded-2xl py-4 px-6 text-white focus:outline-none focus:border-dent-accent/50 transition-all font-bold"
            />
          </div>

          <div class="space-y-2">
            <label class="text-[10px] uppercase tracking-[0.2em] text-slate-500 font-black ml-4"
              >Correo Electrónico</label
            >
            <input
              type="email"
              name="email"
              value={cliente.email}
              required
              class="w-full bg-slate-950 border border-white/5 rounded-2xl py-4 px-6 text-white focus:outline-none focus:border-dent-accent/50 transition-all font-bold"
            />
          </div>
        </div>

        <div
          class="pt-6 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-6"
        >
          <p class="text-slate-500 text-[10px] italic">
            * Al cambiar el email, el usuario deberá usar el nuevo para loguearse.
          </p>

          <button
            type="submit"
            id="submit-btn"
            class="w-full md:w-auto bg-dent-accent text-dent-dark font-black py-4 px-10 rounded-2xl text-xs uppercase tracking-widest hover:scale-105 transition-all shadow-xl shadow-dent-accent/10"
          >
            Actualizar Datos
          </button>
        </div>
      </form>
    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById("edit-form") as HTMLFormElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    btn.innerText = "GUARDANDO...";
    btn.disabled = true;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    try {
      const res = await fetch("/api/admin/clientes/update", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        // Feedback visual de éxito antes de redirigir
        btn.classList.replace("bg-dent-accent", "bg-green-500");
        btn.classList.replace("text-dent-dark", "text-white");
        btn.innerText = "¡ACTUALIZADO!";

        setTimeout(() => {
          window.location.href = "/dashboard/admin/clientes";
        }, 1000);
      } else {
        throw new Error();
      }
    } catch (err) {
      btn.innerText = "ERROR AL GUARDAR";
      btn.classList.add("bg-red-500");
      btn.disabled = false;
      setTimeout(() => {
        btn.innerText = "Actualizar Datos";
        btn.classList.remove("bg-red-500");
      }, 2000);
    }
  });
</script>
