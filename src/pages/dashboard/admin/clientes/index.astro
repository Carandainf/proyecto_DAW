---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import { prisma } from "@/lib/prisma";
import { protectRoute } from "@/lib/auth";

const { user } = await protectRoute(Astro.request, "admin");

// Traemos todos los usuarios con rol 'user'
const clientes = await prisma.user.findMany({
  where: {
    role: "user",
    NOT: { banned: true }, // para ocultar los "borrados"
  },
  include: {
    _count: {
      select: { archivos: true },
    },
  },
  orderBy: { name: "asc" },
});
---

<Layout title="Gestión de Clientes | Admin" darkMode={true}>
  <Navbar />
  <main class="max-w-6xl mx-auto p-4 md:p-8">
    <a
      href="/dashboard/admin"
      class="inline-flex items-center gap-2 text-slate-500 hover:text-dent-accent text-[10px] font-black uppercase tracking-[0.2em] mb-8 transition-colors group"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="3"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="group-hover:-translate-x-1 transition-transform"
        ><path d="m15 18-6-6 6-6"></path></svg
      >
      Volver al Dashboard
    </a>

    <header class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <h1 class="text-4xl font-black italic tracking-tighter text-white">
          Base de <span class="text-dent-accent">Clientes</span>
        </h1>
        <p class="text-slate-500 text-xs uppercase tracking-[0.3em] mt-1 ml-1 font-bold">
          Directorio de doctores y clínicas
        </p>
      </div>
      <a
        href="/dashboard/admin/clientes/nuevo"
        class="bg-dent-accent text-dent-dark font-black py-4 px-8 rounded-2xl text-xs uppercase tracking-widest hover:scale-105 transition-all shadow-xl shadow-dent-accent/10 flex items-center gap-2"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="M5 12h14m-7-7v14"></path></svg
        >
        Registrar Nuevo
      </a>
    </header>

    <div class="mb-8 relative group">
      <div
        class="absolute inset-y-0 left-6 flex items-center pointer-events-none text-slate-500 group-focus-within:text-dent-accent transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg
        >
      </div>
      <input
        type="text"
        id="clienteSearch"
        placeholder="Buscar por nombre, clínica o email..."
        class="w-full bg-dent-card border border-dent-border rounded-3xl py-5 pl-16 pr-6 text-white focus:outline-none focus:border-dent-accent/50 focus:ring-4 focus:ring-dent-accent/5 transition-all shadow-2xl placeholder:text-slate-600 placeholder:uppercase placeholder:text-[10px] placeholder:tracking-widest"
      />
    </div>

    <div class="grid gap-4" id="clientesList">
      {
        clientes.map((cliente) => (
          <div
            class="cliente-card bg-dent-card border border-dent-border p-6 rounded-[2rem] flex flex-col md:flex-row items-center justify-between gap-6 hover:border-dent-accent/30 transition-all shadow-lg hover:shadow-dent-accent/5 group"
            data-name={cliente.name.toLowerCase()}
            data-email={cliente.email.toLowerCase()}
          >
            <div class="flex items-center gap-5 w-full md:w-auto">
              <div class="w-14 h-14 rounded-2xl bg-slate-900 flex items-center justify-center text-dent-accent font-black text-lg border border-white/5 group-hover:border-dent-accent/20 transition-all">
                {cliente.name.substring(0, 2).toUpperCase()}
              </div>
              <div>
                <h3 class="text-white font-black uppercase tracking-tight text-lg">
                  {cliente.name}
                </h3>
                <p class="text-dent-accent/60 text-[10px] font-mono uppercase tracking-wider">
                  {cliente.email}
                </p>
              </div>
            </div>

            <div class="flex items-center gap-10 w-full md:w-auto justify-between md:justify-end border-t md:border-t-0 border-white/5 pt-4 md:pt-0">
              <div class="text-right">
                <span class="block text-2xl font-black text-white italic leading-none">
                  {cliente._count.archivos}
                </span>
                <span class="text-[9px] uppercase text-slate-500 font-black tracking-[0.2em]">
                  Trabajos Totales
                </span>
              </div>

              <div class="flex gap-3">
                <a
                  href={`/dashboard/admin/clientes/editar/${cliente.id}`}
                  class="p-4 bg-slate-900 text-slate-400 rounded-2xl hover:bg-dent-accent hover:text-dent-dark transition-all border border-white/5"
                  title="Editar Perfil"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" />
                      <path d="m15 5 4 4" />
                    </>
                  </svg>
                </a>
                <button
                  class="btn-baja p-4 bg-slate-900 text-red-500/50 rounded-2xl hover:bg-red-500 hover:text-white transition-all border border-white/5"
                  data-id={cliente.id}
                  data-name={cliente.name}
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M3 6h18m-2 0v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2m-6 5 4 4m0-4-4 4" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </main>

  <div
    id="modal-delete"
    class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-slate-950/80 backdrop-blur-sm"
  >
    <div
      class="bg-dent-card border border-red-500/30 w-full max-w-md rounded-[2.5rem] p-8 shadow-2xl scale-95 transition-all"
    >
      <div class="text-center">
        <div
          class="w-16 h-16 bg-red-500/10 text-red-500 rounded-2xl flex items-center justify-center mx-auto mb-6 border border-red-500/20"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M3 6h18m-2 0v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2m-6 5 4 4m0-4-4 4"
            ></path></svg
          >
        </div>
        <h3 class="text-xl font-black text-white italic uppercase tracking-tighter mb-2">
          ¿Confirmar Baja?
        </h3>
        <p class="text-slate-400 text-sm mb-8">
          Vas a dar de baja a <span id="delete-client-name" class="text-white font-bold italic"
          ></span>. El usuario ya no podrá acceder al sistema.
        </p>
      </div>

      <div class="flex flex-col gap-3">
        <button
          id="confirm-delete-btn"
          class="w-full bg-red-500 text-white font-black py-4 rounded-2xl uppercase text-xs tracking-widest hover:bg-red-600 transition-all"
        >
          Confirmar y Procesar
        </button>
        <button
          id="close-delete-modal"
          class="w-full bg-slate-900 text-slate-400 font-black py-4 rounded-2xl uppercase text-[10px] tracking-widest hover:text-white transition-all"
        >
          Cancelar
        </button>
      </div>
    </div>
  </div>
</Layout>

<script>
  // 1. Lógica del Buscador
  const searchInput = document.getElementById("clienteSearch") as HTMLInputElement;
  const cards = document.querySelectorAll(".cliente-card");

  searchInput?.addEventListener("input", () => {
    const val = searchInput.value.toLowerCase();
    cards.forEach((card: any) => {
      const name = card.dataset.name;
      const email = card.dataset.email;
      card.style.display = name.includes(val) || email.includes(val) ? "flex" : "none";
    });
  });

  // 2. Lógica del Modal de Borrado
  const modalDelete = document.getElementById("modal-delete");
  const confirmBtn = document.getElementById("confirm-delete-btn") as HTMLButtonElement;
  const cancelBtn = document.getElementById("close-delete-modal");
  const nameSpan = document.getElementById("delete-client-name");
  let clientIdToDelete: string | null = null;

  document.querySelectorAll(".btn-baja").forEach((btn) => {
    btn.addEventListener("click", () => {
      // Forzamos que el botón sea tratado como HTMLElement para acceder a dataset
      const target = btn as HTMLElement;
      clientIdToDelete = target.getAttribute("data-id");

      if (nameSpan) {
        nameSpan.innerText = target.getAttribute("data-name") || "este cliente";
      }
      modalDelete?.classList.replace("hidden", "flex");
    });
  });

  const closeModal = () => modalDelete?.classList.replace("flex", "hidden");
  cancelBtn?.addEventListener("click", closeModal);

  confirmBtn?.addEventListener("click", async () => {
    if (!clientIdToDelete) return;

    confirmBtn.innerText = "PROCESANDO...";
    confirmBtn.disabled = true;

    try {
      const res = await fetch(`/api/admin/clientes/baja`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id: clientIdToDelete }),
      });
      if (res.ok) {
        location.reload();
      } else {
        throw new Error();
      }
    } catch (err) {
      console.error(err);
      confirmBtn.innerText = "ERROR AL PROCESAR";
      confirmBtn.disabled = false;
      setTimeout(() => (confirmBtn.innerText = "Confirmar y Procesar"), 2000);
    }
  });
</script>
