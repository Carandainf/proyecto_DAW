---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import { prisma } from "@/lib/prisma";
import { protectRoute } from "@/lib/auth";

const { user } = await protectRoute(Astro.request, "admin");

// Traemos todos los usuarios con rol 'user'
const clientes = await prisma.user.findMany({
  where: {
    role: "user",
    NOT: { banned: true }, // para ocultar los "borrados"
  },
  include: {
    _count: {
      select: { archivos: true },
    },
  },
  orderBy: { name: "asc" },
});
---

<Layout title="Gestión de Clientes | Admin">
  <Navbar />
  <main class="max-w-6xl mx-auto p-6 md:p-8">
    <header class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold text-white italic">
          Base de <span class="text-dent-accent">Clientes</span>
        </h1>
        <p class="text-slate-400 text-sm italic">Directorio de doctores y clínicas registradas.</p>
      </div>
      <a
        href="/dashboard/admin/clientes/nuevo"
        class="bg-dent-accent text-dent-dark font-bold py-3 px-6 rounded-2xl text-xs uppercase tracking-widest hover:scale-105 transition-all shadow-lg shadow-cyan-500/10"
      >
        + Registrar Nuevo Cliente
      </a>
    </header>

    <div class="mb-6 relative">
      <input
        type="text"
        id="clienteSearch"
        placeholder="Buscar por nombre o email..."
        class="w-full bg-dent-card border border-dent-border rounded-2xl py-4 px-6 text-white focus:outline-none focus:border-dent-accent/50 transition-all"
      />
    </div>

    <div class="grid gap-4" id="clientesList">
      {
        clientes.map((cliente) => (
          <div
            class="cliente-card bg-dent-card border border-dent-border p-5 rounded-2xl flex flex-col md:flex-row items-center justify-between gap-6 hover:border-dent-accent/30 transition-all"
            data-name={cliente.name.toLowerCase()}
            data-email={cliente.email.toLowerCase()}
          >
            <div class="flex items-center gap-4 w-full md:w-auto">
              <div class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center text-dent-accent font-bold border border-slate-700">
                {cliente.name.substring(0, 2).toUpperCase()}
              </div>
              <div>
                <h3 class="text-white font-bold">{cliente.name}</h3>
                <p class="text-slate-500 text-xs font-mono">{cliente.email}</p>
              </div>
            </div>

            <div class="flex items-center gap-8 w-full md:w-auto justify-between md:justify-end">
              <div class="text-center">
                <span class="block text-xl font-bold text-slate-300">
                  {cliente._count.archivos}
                </span>
                <span class="text-[9px] uppercase text-slate-500 font-black tracking-tighter">
                  Trabajos
                </span>
              </div>

              <div class="flex gap-2">
                <a
                  href={`/dashboard/admin/clientes/editar/${cliente.id}`}
                  class="p-3 bg-slate-800 text-slate-300 rounded-xl hover:bg-dent-accent hover:text-dent-dark transition-all"
                  title="Editar Perfil"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" />
                      <path d="m15 5 4 4" />
                    </>
                  </svg>
                </a>
                <button
                  class="btn-baja p-3 bg-slate-800 text-red-400 rounded-xl hover:bg-red-500 hover:text-white transition-all"
                  data-id={cliente.id}
                  data-name={cliente.name}
                  title="Dar de baja"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <path d="M3 6h18" />
                      <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" />
                      <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" />
                      <line x1="10" x2="14" y1="11" y2="17" />
                      <line x1="14" x2="10" y1="11" y2="17" />
                    </>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </main>
</Layout>

<script>
  // Buscador en tiempo real
  const searchInput = document.getElementById("clienteSearch") as HTMLInputElement;
  const cards = document.querySelectorAll(".cliente-card");

  searchInput?.addEventListener("input", () => {
    const val = searchInput.value.toLowerCase();
    cards.forEach((card: any) => {
      const name = card.dataset.name;
      const email = card.dataset.email;
      card.style.display = name.includes(val) || email.includes(val) ? "flex" : "none";
    });
  });

  // Manejo de bajas
  const botonesBaja = document.querySelectorAll(".btn-baja");

  botonesBaja.forEach((boton) => {
    boton.addEventListener("click", async () => {
      const id = boton.getAttribute("data-id");
      const nombre = boton.getAttribute("data-name");

      if (confirm(`¿Estás seguro de que quieres dar de baja al usuario ${nombre}?`)) {
        try {
          const res = await fetch(`/api/admin/clientes/baja`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id }),
          });
          if (res.ok) location.reload();
        } catch (err) {
          console.error("Error al procesar la baja:", err);
        }
      }
    });
  });
</script>
