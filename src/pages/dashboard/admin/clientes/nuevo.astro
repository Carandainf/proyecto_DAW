---
/**
 * @file nuevo.astro
 * @description Interfaz de registro para nuevos clientes/doctores.
 * Proporciona un formulario validado para la creación de cuentas de acceso.
 * * @requires Layout - Contenedor principal de la aplicación.
 * @requires protectRoute - Middleware de seguridad para asegurar rango admin.
 */

import Layout from "@/layouts/Layout.astro";
import { protectRoute } from "@/lib/auth";

/** Verificación de seguridad en el servidor */
await protectRoute(Astro.request, "admin");
---

<Layout title="Registrar Cliente | Admin" darkMode={true}>
  <main
    class="min-h-screen pt-28 md:pt-36 pb-12 px-4 max-w-2xl mx-auto transition-all animate-fade-in"
  >
    <nav class="mb-10">
      <a
        href="/dashboard/admin/clientes"
        class="inline-flex items-center gap-2 text-slate-500 hover:text-dent-accent text-[10px] font-black uppercase tracking-[0.2em] transition-all group"
      >
        <div class="p-2 rounded-full group-hover:bg-dent-accent/10 transition-colors">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="group-hover:-translate-x-1 transition-transform"
            ><path d="m15 18-6-6 6-6"></path></svg
          >
        </div>
        Volver al directorio
      </a>
    </nav>

    <div
      class="bg-dent-card border border-dent-border p-8 md:p-12 rounded-[3.5rem] shadow-2xl relative overflow-hidden group"
    >
      <div
        class="absolute top-0 right-0 w-48 h-48 bg-dent-accent/5 rounded-full -mr-24 -mt-24 blur-3xl group-hover:bg-dent-accent/10 transition-colors duration-700"
      >
      </div>

      <header class="mb-12 relative z-10">
        <h1 class="text-5xl font-black italic tracking-tighter text-white leading-none">
          Nuevo <span class="text-dent-accent">Registro</span>
        </h1>
        <p class="text-slate-500 text-[10px] uppercase tracking-[0.3em] font-bold mt-4 opacity-80">
          Crea credenciales de acceso para profesionales
        </p>
      </header>

      <form id="createClientForm" class="space-y-8 relative z-10">
        <div class="group/input space-y-3">
          <label
            class="block text-[10px] uppercase font-black text-slate-500 ml-2 tracking-widest group-focus-within/input:text-dent-accent transition-colors"
          >
            Identificación (Clínica / Doctor)
          </label>
          <div class="relative">
            <input
              name="name"
              type="text"
              placeholder="Ej: Clínica Dental Central"
              required
              class="w-full bg-slate-900/40 border border-white/5 text-white p-6 rounded-2xl outline-none focus:border-dent-accent/50 focus:ring-8 focus:ring-dent-accent/5 transition-all font-medium placeholder:text-slate-700 shadow-inner"
            />
          </div>
        </div>

        <div class="group/input space-y-3">
          <label
            class="block text-[10px] uppercase font-black text-slate-500 ml-2 tracking-widest group-focus-within/input:text-dent-accent transition-colors"
          >
            Email de Autenticación
          </label>
          <input
            name="email"
            type="email"
            placeholder="doctor@ejemplo.com"
            required
            class="w-full bg-slate-900/40 border border-white/5 text-white p-6 rounded-2xl outline-none focus:border-dent-accent/50 focus:ring-8 focus:ring-dent-accent/5 transition-all font-medium placeholder:text-slate-700 shadow-inner"
          />
        </div>

        <div class="group/input space-y-3">
          <label
            class="block text-[10px] uppercase font-black text-slate-500 ml-2 tracking-widest group-focus-within/input:text-dent-accent transition-colors"
          >
            Contraseña Temporal
          </label>
          <input
            name="password"
            type="password"
            placeholder="••••••••••••"
            required
            class="w-full bg-slate-900/40 border border-white/5 text-white p-6 rounded-2xl outline-none focus:border-dent-accent/50 focus:ring-8 focus:ring-dent-accent/5 transition-all font-medium placeholder:text-slate-700 shadow-inner"
          />
          <p
            class="text-[9px] text-slate-600 font-bold uppercase tracking-tight ml-2 italic leading-relaxed"
          >
            * El cliente recibirá un email con este acceso y podrá restablecerlo <br /> mediante la opción
            "He olvidado mi contraseña" en el login.
          </p>
        </div>

        <button
          type="submit"
          id="submitBtn"
          class="w-full bg-dent-accent text-dent-dark font-black py-6 rounded-[1.5rem] uppercase text-xs tracking-[0.4em] shadow-2xl shadow-dent-accent/10 hover:shadow-dent-accent/20 hover:scale-[1.01] active:scale-95 transition-all mt-6 flex items-center justify-center gap-3 cursor-pointer group/btn"
        >
          <span id="btnText">Dar de alta cliente</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="group-hover/btn:translate-x-1 transition-transform"
            ><path d="M5 12h14m-7-7 7 7-7 7"></path></svg
          >
        </button>

        <div
          id="feedback"
          class="hidden text-center text-[10px] font-black uppercase mt-8 tracking-[0.2em] px-6 py-4 rounded-2xl bg-white/5 border border-white/5 animate-fade-in"
        >
        </div>
      </form>
    </div>
  </main>
</Layout>

<script>
  /**
   * @module NewClientLogic
   * @description Maneja el envío asíncrono del formulario de registro y el feedback de usuario.
   */

  /** @type {HTMLFormElement} */
  const form = document.getElementById("createClientForm") as HTMLFormElement;
  /** @type {HTMLButtonElement} */
  const btn = document.getElementById("submitBtn") as HTMLButtonElement;
  /** @type {HTMLElement} */
  const btnText = document.getElementById("btnText") as HTMLElement;
  /** @type {HTMLElement} */
  const feedback = document.getElementById("feedback") as HTMLElement;

  // Limpiar feedback al empezar a editar cualquier campo
  form.addEventListener("input", () => {
    if (feedback.classList.contains("block")) {
      feedback.classList.remove("block");
      feedback.classList.add("hidden");
    }
  });

  /**
   * Procesa el evento submit del formulario.
   * Envia los datos al endpoint de creación de clientes.
   * @param {SubmitEvent} e - Evento de envío del formulario.
   */
  form?.addEventListener("submit", async (e: SubmitEvent) => {
    e.preventDefault();

    // Estado de carga
    btn.disabled = true;
    btn.classList.add("opacity-50", "grayscale");
    btnText.innerText = "PROCESANDO REGISTRO...";

    const fd = new FormData(form);
    const data = Object.fromEntries(fd);

    try {
      const res = await fetch("/api/admin/clientes/crear", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        // Éxito: Feedback visual y redirección
        feedback.textContent = "✓ Cuenta creada correctamente. Redirigiendo...";
        feedback.className =
          "text-center text-[10px] font-black uppercase mt-8 tracking-[0.2em] px-6 py-4 rounded-2xl bg-dent-accent/10 text-dent-accent border border-dent-accent/20 block animate-fade-in";

        setTimeout(() => (window.location.href = "/dashboard/admin/clientes"), 1500);
      } else {
        // Manejo de errores controlados (ej: email duplicado)
        const errorData = await res.json();
        throw new Error(errorData.message || "Error en el servidor");
      }
    } catch (err) {
      // Error: Restauración del estado y mensaje de aviso
      console.error("[Create Client Error]:", err);

      feedback.textContent = "✕ El email ya existe o los datos son inválidos";
      feedback.className =
        "text-center text-[10px] font-black uppercase mt-8 tracking-[0.2em] px-6 py-4 rounded-2xl bg-red-500/10 text-red-500 border border-red-500/20 block animate-fade-in";

      btn.disabled = false;
      btn.classList.remove("opacity-50", "grayscale");
      btnText.innerText = "DAR DE ALTA CLIENTE";
    }
  });
</script>

<style>
  /** Animación sutil de entrada */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }
</style>
