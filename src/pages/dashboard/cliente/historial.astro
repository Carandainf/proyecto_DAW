---
/**
 * HISTORIAL DE TRABAJOS (CLIENTE)
 * @description Historial con buscador, filtro de estado y exportación PDF personalizada.
 */
import Layout from "@/layouts/Layout.astro";
import { protectRoute } from "@/lib/auth";
import { prisma } from "@/lib/prisma";

const { shouldRedirect, url, user } = await protectRoute(Astro.request, "user");
if (shouldRedirect) return Astro.redirect(url);

const todosLosTrabajos = await prisma.archivo.findMany({
  where: { id_usuario: user?.id },
  orderBy: { fecha_subida: "desc" },
});
---

<Layout title="Historial | DentalLab" darkMode={true}>
  <main
    class="min-h-screen pt-28 md:pt-36 pb-12 px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto transition-all"
  >
    <header
      class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-6 mb-12 relative"
    >
      <div class="relative z-10">
        <button
          onclick="history.back()"
          class="inline-flex items-center gap-2 text-slate-500 hover:text-dent-accent transition-colors text-[10px] font-black uppercase tracking-widest mb-4 group cursor-pointer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            class="group-hover:-translate-x-1 transition-transform"
          >
            <path d="m15 18-6-6 6-6"></path>
          </svg>
          Volver al panel
        </button>

        <h1 class="text-4xl md:text-5xl font-black text-white italic uppercase tracking-tighter">
          Historial <span class="text-dent-accent">Digital</span>
        </h1>
        <p class="text-slate-500 font-medium mt-2 max-w-md">
          Gestión integral de archivos, estados de producción y comunicación con el laboratorio.
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-3 relative z-10 w-full lg:w-auto">
        <input
          type="text"
          id="searchBox"
          placeholder="BUSCAR TRABAJO..."
          class="bg-dent-card border border-dent-border rounded-full px-6 py-3 text-[10px] font-black text-white outline-none focus:border-dent-accent transition-all w-full sm:w-[200px] uppercase tracking-widest"
        />

        <select
          id="statusFilter"
          class="bg-dent-card border border-dent-border rounded-full px-6 py-3 text-[10px] font-black text-slate-200 uppercase outline-none cursor-pointer hover:border-dent-accent transition-all tracking-widest"
        >
          <option value="all">TODOS</option>
          <option value="pendiente">PENDIENTE</option>
          <option value="en_proceso">EN PROCESO</option>
          <option value="completado">COMPLETADO</option>
        </select>

        <button
          id="downloadPDF"
          class="bg-dent-accent hover:bg-white text-dent-dark px-6 py-3 rounded-full font-black text-[10px] tracking-widest transition-all shadow-xl shadow-cyan-500/10 flex items-center gap-2 uppercase group"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            class="group-hover:translate-y-0.5 transition-transform"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          Exportar PDF
        </button>
      </div>
    </header>

    <div
      class="bg-dent-card border border-dent-border rounded-[2rem] overflow-hidden shadow-2xl relative"
    >
      <div class="overflow-x-auto no-scrollbar">
        <table class="w-full text-left border-collapse" id="historyTable">
          <thead>
            <tr class="bg-dent-dark/50 border-b border-dent-border/50">
              <th class="p-6 text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]"
                >Fecha</th
              >
              <th class="p-6 text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]"
                >Nombre del Trabajo</th
              >
              <th
                class="p-6 text-[10px] font-black text-slate-500 uppercase tracking-[0.2em] text-center"
                >Estado</th
              >
              <th
                class="p-6 text-[10px] font-black text-slate-500 uppercase tracking-[0.2em] text-right"
                >Acciones</th
              >
            </tr>
          </thead>
          <tbody class="divide-y divide-dent-border/30">
            {
              todosLosTrabajos.map((trabajo) => (
                <tr
                  class="history-row hover:bg-white/[0.02] transition-colors group"
                  data-status={trabajo.estado}
                  data-name={trabajo.nombre_archivo.toLowerCase()}
                >
                  <td class="p-6">
                    <span class="text-xs font-bold text-slate-400 font-mono">
                      {new Date(trabajo.fecha_subida).toLocaleDateString("es-ES")}
                    </span>
                  </td>
                  <td class="p-6">
                    <span class="text-sm text-slate-200 font-bold">{trabajo.nombre_archivo}</span>
                  </td>
                  <td class="p-6 text-center">
                    <span
                      class={`inline-block px-4 py-1.5 rounded-full text-[9px] font-black uppercase border ${
                        trabajo.estado === "pendiente"
                          ? "bg-amber-500/10 text-amber-500 border-amber-500/20"
                          : trabajo.estado === "en_proceso"
                            ? "bg-cyan-500/10 text-cyan-400 border-cyan-500/20"
                            : "bg-emerald-500/10 text-emerald-500 border-emerald-500/20"
                      }`}
                    >
                      {trabajo.estado.replace("_", " ")}
                    </span>
                  </td>
                  <td class="p-6 text-right">
                    <a
                      href={`/api/downloads/${trabajo.id_archivo}`}
                      class="text-slate-500 hover:text-dent-accent"
                    >
                      Descargar
                    </a>
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </main>
</Layout>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"
></script>
<script
  is:inline
  src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"
></script>

<script define:vars={{ todosLosTrabajos }}>
  const searchBox = document.getElementById("searchBox");
  const statusFilter = document.getElementById("statusFilter");
  const rows = document.querySelectorAll(".history-row");

  function filterTable() {
    const searchTerm = searchBox.value.toLowerCase();
    const statusTerm = statusFilter.value;
    rows.forEach((row) => {
      const matchName = row.getAttribute("data-name").includes(searchTerm);
      const matchStatus = statusTerm === "all" || row.getAttribute("data-status") === statusTerm;
      row.style.display = matchName && matchStatus ? "" : "none";
    });
  }

  searchBox?.addEventListener("input", filterTable);
  statusFilter?.addEventListener("change", filterTable);

  document.getElementById("downloadPDF")?.addEventListener("click", () => {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF();

    doc.setFillColor(2, 6, 23);
    doc.rect(0, 0, 210, 40, "F");
    doc.setFont("helvetica", "bold");
    doc.setFontSize(24);
    doc.setTextColor(6, 182, 212);
    doc.text("DENTAL LAB", 15, 25);
    doc.setFontSize(10);
    doc.setTextColor(150);
    doc.text("INFORME DE PRODUCCIÓN DIGITAL", 15, 33);
    doc.text(`Generado el: ${new Date().toLocaleString("es-ES")}`, 140, 25);

    const rowsData = todosLosTrabajos.map((t) => [
      new Date(t.fecha_subida).toLocaleDateString("es-ES"),
      t.nombre_archivo,
      t.estado.toUpperCase().replace("_", " "),
    ]);

    doc.autoTable({
      startY: 50,
      head: [["FECHA", "ARCHIVO / REFERENCIA", "ESTADO"]],
      body: rowsData,
      theme: "grid",
      headStyles: { fillColor: [6, 182, 212], textColor: [2, 6, 23], halign: "center" },
      columnStyles: { 0: { halign: "center", cellWidth: 30 }, 2: { halign: "center" } },
    });

    doc.save(`DentalLab_Historial_${new Date().toISOString().split("T")[0]}.pdf`);
  });
</script>
