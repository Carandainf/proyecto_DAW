---
// index.astro (Cliente)
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import { protectRoute } from "@/lib/auth";
import { prisma } from "@/lib/prisma";

// 1. Protegemos la ruta
const { shouldRedirect, url, user, role } = await protectRoute(Astro.request, "user");

if (shouldRedirect) {
  return Astro.redirect(url);
}

/**
 * Como hemos pasado el 'shouldRedirect', sabemos que 'user' existe.
 * Si volvemos a validar 'if (!user)', TS "limpia" el tipo y
 * a partir de aquí user.id ya no dará erroren ninguna parte del código.
 */
if (!user) return Astro.redirect("/");

// 2. Buscamos los últimos 5 archivos subidos
const misTrabajos = await prisma.archivo.findMany({
  where: {
    id_usuario: user.id,
  },
  orderBy: {
    fecha_subida: "desc",
  },
  take: 5,
});

// 3. Obtener los últimos 5 mensajes de cualquier trabajo del cliente
const ultimasNotificaciones = await prisma.mensaje.findMany({
  where: {
    archivo: {
      id_usuario: user.id, // Mensajes de SUS trabajos
    },
    // Solo mensajes que NO sean suyos (del lab)
    id_emisor: { not: user.id },
  },
  take: 5,
  orderBy: { fecha_envio: "desc" },
  include: {
    archivo: true,
    emisor: true,
  },
});
---

<Layout bodyClass="p-0" title="Panel de Administración" darkMode={true} />
<Navbar />

<main class="max-w-7xl mx-auto p-4 md:p-8">
  <header class="mb-8">
    <h1 class="text-3xl font-bold text-slate-100">
      Bienvenido, <span class="text-dent-accent">{user?.name}</span>
    </h1>
    <p class="text-slate-400">Panel de gestión de trabajos dentales</p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-3 md:grid-rows-2 gap-4 auto-rows-[200px]">
    <section
      class="relative md:col-span-2 md:row-span-2 bg-dent-card border border-dent-border rounded-3xl p-8 flex flex-col hover:border-dent-accent/30 transition-all shadow-xl"
    >
      <div class="flex items-center gap-4 mb-6">
        <div class="p-3 bg-dent-accent/10 rounded-2xl">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-8 h-8 text-dent-accent"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline
              points="17 8 12 3 7 8"></polyline><line x1="12" x2="12" y1="3" y2="15"></line></svg
          >
        </div>
        <div>
          <h2 class="text-2xl font-bold text-slate-100">Nueva Orden de Trabajo</h2>
          <p class="text-slate-400 text-sm">Configure los detalles de su diseño 3D</p>
        </div>
      </div>

      <form id="upload-form" class="flex-1 grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div class="relative group">
          <label
            for="file-upload"
            class="flex flex-col items-center justify-center h-full border-2 border-dashed border-dent-border rounded-2xl bg-dent-dark/30 group-hover:bg-dent-dark/50 group-hover:border-dent-accent/50 transition-all duration-300 cursor-pointer p-6 text-center"
          >
            <div
              class="p-4 bg-dent-dark rounded-full mb-4 group-hover:scale-110 transition-transform"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-10 h-10 text-slate-500 group-hover:text-dent-accent"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"></path><path
                  d="M12 12v9"></path><path d="m16 16-4-4-4 4"></path></svg
              >
            </div>
            <p class="text-slate-300 font-medium">Arrastre su archivo .STL</p>
            <p class="text-xs text-slate-500 mt-2">O haga clic para explorar carpetas</p>
            <input id="file-upload" type="file" accept=".stl" class="hidden" multiple />
          </label>
          <div
            id="file-name-preview"
            class="hidden absolute bottom-4 left-4 right-4 bg-dent-accent/20 border border-dent-accent/30 p-2 rounded-lg text-xs text-dent-accent text-center truncate"
          >
            Archivo seleccionado
          </div>
        </div>

        <div class="flex flex-col gap-5">
          <div class="space-y-2">
            <label class="text-sm font-medium text-slate-300"
              >Observaciones para el Laboratorio</label
            >
            <textarea
              class="w-full bg-dent-dark border border-dent-border rounded-xl p-3 text-sm text-slate-200 focus:outline-none focus:ring-2 focus:ring-dent-accent/50 min-h-30 resize-none"
              placeholder="Ej: Ajustar oclusión en pieza 46, usar resina de alta precisión..."
            ></textarea>
          </div>

          <div class="space-y-2">
            <label class="text-sm font-medium text-slate-300">Prioridad</label>
            <select
              class="w-full bg-dent-dark border border-dent-border rounded-xl p-3 text-sm text-slate-200 focus:outline-none focus:ring-2 focus:ring-dent-accent/50"
            >
              <option value="normal">Estándar (3-5 días)</option>
              <option value="urgente">Urgente (24-48h)</option>
            </select>
          </div>

          <div class="mt-auto">
            <button
              type="submit"
              class="w-full bg-dent-accent hover:bg-cyan-400 text-dent-dark font-bold py-4 rounded-xl transition-all flex items-center justify-center gap-2 shadow-lg shadow-dent-accent/20"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"><path d="m5 12 5 5L19 7"></path></svg
              >
              ENVIAR TRABAJO
            </button>
            <p class="text-[10px] text-center text-slate-500 mt-3 uppercase tracking-widest">
              Se notificará al administrador al instante
            </p>
          </div>
        </div>
      </form>
      <div
        id="success-message"
        class="hidden absolute inset-0 bg-dent-card rounded-3xl flex-col items-center justify-center text-center p-8 z-10"
      >
      </div>
      <div
        class="w-20 h-20 bg-emerald-500/20 text-emerald-500 rounded-full flex items-center justify-center mb-4 animate-bounce"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-12 h-12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg
        >
      </div>
      <h3 class="text-2xl font-bold text-slate-100 italic">¡Trabajo Recibido!</h3>
      <p class="text-slate-400 mt-2">
        El archivo se ha subido correctamente.<br />Ya puedes verlo en tu historial.
      </p>
      <button
        onclick="location.reload()"
        class="mt-6 text-dent-accent hover:underline text-sm font-medium">Subir otro archivo</button
      >
    </section>
  </div>

  <section
    class="bg-dent-card border border-dent-border rounded-3xl p-6 flex flex-col hover:border-dent-accent/50 transition-colors shadow-lg h-full"
  >
    <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
      <span class="relative flex h-3 w-3">
        <span
          class="animate-ping absolute inline-flex h-full w-full rounded-full bg-dent-accent opacity-75"
        ></span>
        <span class="relative inline-flex rounded-full h-3 w-3 bg-dent-accent"></span>
      </span>
      Actividad Reciente
    </h2>

    <div class="flex-1 space-y-4 overflow-y-auto pr-2 custom-scrollbar min-h-50">
      {
        ultimasNotificaciones.length === 0 ? (
          <div class="h-full flex items-center justify-center">
            <p class="text-slate-500 text-sm italic text-center">
              No hay mensajes nuevos del laboratorio.
            </p>
          </div>
        ) : (
          ultimasNotificaciones.map((notif) => (
            <a
              href={`/dashboard/cliente/trabajo/${notif.id_archivo}`}
              class="block p-3 rounded-xl bg-dent-dark/50 border border-dent-border hover:border-dent-accent/30 transition-all group"
            >
              <div class="flex justify-between items-start mb-1">
                <span class="text-[10px] font-bold text-dent-accent uppercase truncate mr-2">
                  {notif.archivo.nombre_archivo}
                </span>
                <span class="text-[9px] text-slate-500 whitespace-nowrap">
                  {new Date(notif.fecha_envio).toLocaleTimeString([], {
                    hour: "2-digit",
                    minute: "2-digit",
                  })}
                </span>
              </div>
              <p class="text-xs text-slate-300 line-clamp-2 group-hover:text-white transition-colors">
                <span class="font-bold text-slate-400">{notif.emisor.name}:</span> "
                {notif.contenido}"
              </p>
            </a>
          ))
        )
      }
    </div>

    <a
      href="/dashboard/cliente/historial"
      class="text-center mt-4 text-dent-accent text-xs hover:underline font-medium"
    >
      Ir a la mensajería →
    </a>
  </section>

  <section
    class="bg-dent-card border border-dent-border rounded-3xl p-6 flex flex-col hover:border-dent-accent/50 transition-colors shadow-lg"
  >
    <div class="flex items-center gap-3 mb-4">
      <div class="p-2 bg-emerald-500/10 rounded-lg">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6 text-emerald-400"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          ><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline
            points="14 2 14 8 20 8"></polyline><line x1="16" x2="8" y1="13" y2="13"></line><line
            x1="16"
            x2="8"
            y1="17"
            y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg
        >
      </div>
      <h2 class="text-lg font-semibold text-slate-100">Mis Trabajos</h2>
    </div>

    <div class="flex-1 space-y-3 overflow-y-auto max-h-55 pr-2 custom-scrollbar">
      {
        misTrabajos.length === 0 ? (
          <p class="text-slate-500 text-xs italic text-center py-4">
            No has subido ningún trabajo todavía.
          </p>
        ) : (
          misTrabajos.map((trabajo) => (
            /* 1. Usamos el enlace como contenedor principal */
            <a
              href={`/dashboard/cliente/trabajo/${trabajo.id_archivo}`}
              class="flex justify-between items-center text-xs p-3 bg-dent-dark/50 rounded-lg border border-dent-border hover:border-dent-accent/30 hover:bg-dent-dark/80 transition-all group mb-2 last:mb-0"
            >
              {/* 2. Columna Izquierda: Nombre y Fecha */}
              <div class="flex flex-col gap-1 truncate mr-2">
                <span class="text-slate-200 font-medium truncate flex items-center gap-1 group-hover:text-dent-accent transition-colors">
                  {trabajo.nombre_archivo}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="10"
                    height="10"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="opacity-0 group-hover:opacity-100 transition-opacity"
                  >
                    <path d="M5 12h14m-7-7 7 7-7 7" />
                  </svg>
                </span>
                <span class="text-[10px] text-slate-500">
                  {new Date(trabajo.fecha_subida).toLocaleDateString("es-ES")}
                </span>
              </div>

              {/* 3. Columna Derecha: Estado */}
              <span
                class={`px-2 py-1 rounded text-[9px] font-bold uppercase whitespace-nowrap ${
                  trabajo.estado === "pendiente"
                    ? "bg-amber-500/10 text-amber-500 border border-amber-500/20"
                    : trabajo.estado === "recibido"
                      ? "bg-blue-500/10 text-blue-400 border border-blue-500/20"
                      : "bg-emerald-500/10 text-emerald-500 border border-emerald-500/20"
                }`}
              >
                {trabajo.estado}
              </span>
            </a>
          ))
        )
      }
    </div>

    <a
      href="/dashboard/cliente/historial"
      class="text-center mt-4 text-dent-accent text-xs hover:underline font-medium"
    >
      Ver historial completo →
    </a>
  </section>
</main>

<script>
  const form = document.getElementById("upload-form") as HTMLFormElement;
  const fileInput = document.getElementById("file-upload") as HTMLInputElement;
  const preview = document.getElementById("file-name-preview");

  // Seleccionamos la zona visual (el label que envuelve al input)
  const dropzone = fileInput?.closest("label");

  // --- COMIENZO ZONA DRAG & DROP. Ya que si lo dejo de manera automática
  // lo que hace es visualizar el archivo ---

  // 1. Prevenir que el navegador abra el archivo al soltarlo
  ["dragenter", "dragover", "dragleave", "drop"].forEach((eventName) => {
    dropzone?.addEventListener(
      eventName,
      (e) => {
        e.preventDefault();
        e.stopPropagation();
      },
      false
    );
  });

  // 2. Efectos visuales cuando el archivo está sobre la zona
  ["dragenter", "dragover"].forEach((eventName) => {
    dropzone?.addEventListener(
      eventName,
      () => {
        // Añadimos borde cian, fondo sutil y escalamos un poco la caja
        dropzone.classList.add("border-dent-accent", "bg-dent-accent/10", "scale-[1.01]");
        dropzone.classList.remove("border-dent-border");
      },
      false
    );
  });

  ["dragleave", "drop"].forEach((eventName) => {
    dropzone?.addEventListener(
      eventName,
      () => {
        // Volvemos al estado original
        dropzone.classList.remove("border-dent-accent", "bg-dent-accent/10", "scale-[1.01]");
        dropzone.classList.add("border-dent-border");
      },
      false
    );
  });

  // 3. Capturar el archivo cuando se suelta
  dropzone?.addEventListener(
    "drop",
    (e) => {
      const dt = e.dataTransfer;
      const files = dt?.files;

      if (files && files.length > 0) {
        // Importante: Asignamos los archivos arrastrados al input oculto
        fileInput.files = files;

        // Lanzamos manualmente el evento 'change' para que se actualice la vista del nombre
        fileInput.dispatchEvent(new Event("change"));
      }
    },
    false
  );
  // --- FIN ZONA DRAG & DROP ---

  // Mostrar el nombre del archivo al seleccionarlo
  fileInput?.addEventListener("change", () => {
    // Comprobamos si hay archivos y si existe el elemento preview
    if (fileInput.files && fileInput.files.length > 0 && preview) {
      // Si solo hay 1 archivo, mostramos su nombre original
      if (fileInput.files.length === 1) {
        preview.innerText = `📄 Seleccionado: ${fileInput.files[0].name}`;
      }
      // Si hay varios, mostramos el total de archivos detectados
      else {
        preview.innerText = `📚 Seleccionados: ${fileInput.files.length} archivos .STL`;
      }

      // Mostramos el cartel de éxito
      preview.classList.remove("hidden");
    }
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const formData = new FormData();
    const files = fileInput.files;
    const descripcion = (form.querySelector("textarea") as HTMLTextAreaElement).value;
    const prioridad = (form.querySelector("select") as HTMLSelectElement).value;

    // CONTROLO SI HA CARGADO ALGÚN FICHERO
    if (!files || files.length === 0) return alert("Selecciona un archivo primero");

    // Recorremos todos los archivos y los añadimos al FormData
    for (const file of files) {
      formData.append("files", file);
    }
    formData.append("descripcion", descripcion);
    formData.append("prioridad", prioridad);

    try {
      const response = await fetch("/api/upload", {
        method: "POST",
        body: formData,
      });

      const result = await response.json();

      if (response.ok) {
        // --- Si todo sale bien, lo notificamos al usuario ---
        const successBox = document.getElementById("success-message");
        const uploadForm = document.getElementById("upload-form");

        // 1. Limpiamos los campos manualmente, ya que el reset() no me esta funcionando
        (uploadForm as HTMLFormElement).reset();
        document.getElementById("file-name-preview")?.classList.add("hidden");

        uploadForm?.classList.add("opacity-0", "pointer-events-none");
        successBox?.classList.remove("hidden");
        successBox?.classList.add("flex");
        successBox?.classList.add("animate-in", "fade-in", "zoom-in", "duration-300");

        setTimeout(() => {
          location.reload();
        }, 4000);
      } else {
        // --- Si hay un erroral subir el fichero, lo notificamos al usuario ---
        alert("Atención: " + result.error);
      }
    } catch (err) {
      alert("Error de conexión");
    }
  });
</script>
