---
// index.astro (Cliente)
import Layout from "@/layouts/Layout.astro";
import { protectRoute } from "@/lib/auth";
import { prisma } from "@/lib/prisma";

const { shouldRedirect, url, user } = await protectRoute(Astro.request, "user");

if (shouldRedirect) return Astro.redirect(url);
if (!user) return Astro.redirect("/");

// 2. Buscamos los últimos 5 archivos subidos
const misTrabajos = await prisma.archivo.findMany({
  where: { id_usuario: user.id },
  orderBy: { fecha_subida: "desc" },
  take: 5,
});

// 3. Obtener los últimos 5 mensajes del laboratorio para este cliente
const ultimasNotificaciones = await prisma.mensaje.findMany({
  where: {
    archivo: { id_usuario: user.id },
    id_emisor: { not: user.id },
  },
  take: 5,
  orderBy: { fecha_envio: "desc" },
  include: { archivo: true, emisor: true },
});
---

<Layout title="Mi Panel - DentalLab" darkMode={true}>
  <main
    class="min-h-screen pt-28 md:pt-36 pb-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto transition-all"
  >
    <header class="mb-10 relative">
      <div class="absolute -left-4 top-0 w-1 h-12 bg-dent-accent rounded-full hidden md:block">
      </div>
      <h1 class="text-3xl md:text-5xl font-black text-slate-100 tracking-tighter italic uppercase">
        Hola, <span class="text-dent-accent">{user?.name.split(" ")[0]}</span>
      </h1>
      <p class="text-slate-500 font-medium mt-2 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-status-success animate-pulse"></span>
        Estado del sistema: Conectado al Laboratorio
      </p>
    </header>

    <div class="flex flex-col gap-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <section
          class="lg:col-span-2 bg-dent-card border border-dent-border rounded-[2.5rem] p-6 md:p-10 flex flex-col hover:border-dent-accent/30 transition-all shadow-2xl relative overflow-hidden group"
        >
          <div
            class="absolute -top-24 -right-24 w-64 h-64 bg-dent-accent/5 rounded-full blur-[80px] pointer-events-none"
          >
          </div>

          <div class="flex items-center gap-5 mb-8 relative z-10">
            <div
              class="w-14 h-14 bg-dent-accent/10 rounded-2xl flex items-center justify-center border border-dent-accent/20"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-7 h-7 text-dent-accent"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline
                  points="17 8 12 3 7 8"></polyline><line x1="12" x2="12" y1="3" y2="15"
                ></line></svg
              >
            </div>
            <div>
              <h2 class="text-2xl font-black text-white italic tracking-tight uppercase">
                Nueva Orden
              </h2>
              <p class="text-slate-500 text-xs font-bold uppercase tracking-widest">
                Configuración Diseño 3D
              </p>
            </div>
          </div>

          <form id="upload-form" class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-8 relative z-10">
            <div class="relative h-full min-h-[220px]">
              <label
                for="file-upload"
                class="flex flex-col items-center justify-center h-full border-2 border-dashed border-dent-border rounded-[2rem] bg-dent-dark/30 hover:bg-dent-dark/50 hover:border-dent-accent/50 transition-all cursor-pointer p-6 text-center group/drop"
              >
                <div
                  class="p-4 bg-dent-dark rounded-2xl mb-4 group-hover/drop:scale-110 transition-transform shadow-xl"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-10 h-10 text-slate-500 group-hover/drop:text-dent-accent"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    ><path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"></path><path
                      d="M12 12v9"></path><path d="m16 16-4-4-4 4"></path></svg
                  >
                </div>
                <p class="text-slate-300 text-sm font-bold uppercase tracking-tight">
                  Suelte su archivo <span class="text-dent-accent">.STL</span>
                </p>
                <input id="file-upload" type="file" accept=".stl" class="hidden" multiple />
              </label>
              <div
                id="file-name-preview"
                class="hidden absolute bottom-4 left-4 right-4 bg-dent-accent text-dent-dark p-2 rounded-xl text-[10px] font-black uppercase text-center truncate"
              >
                Archivo seleccionado
              </div>
            </div>

            <div class="flex flex-col gap-5">
              <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]"
                  >Observaciones Técnicas</label
                >
                <textarea
                  class="w-full bg-dent-dark/50 border border-dent-border rounded-[1.5rem] p-4 text-sm text-slate-200 focus:ring-2 focus:ring-dent-accent/30 min-h-[100px] resize-none outline-none transition-all"
                  placeholder="Muñones, material, color..."></textarea>
              </div>
              <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]"
                  >Prioridad</label
                >
                <select
                  class="w-full bg-dent-dark/50 border border-dent-border rounded-full px-5 py-3 text-sm text-slate-200 outline-none appearance-none cursor-pointer [&>option]:bg-slate-900 [&>option]:text-slate-200"
                >
                  <option value="normal">Estándar (3-5 días)</option>
                  <option value="urgente">Urgente (24-48h)</option>
                </select>
              </div>
              <button
                type="submit"
                class="w-full bg-dent-accent hover:bg-white text-dent-dark font-black py-4 rounded-full transition-all uppercase text-xs tracking-widest"
                >Enviar al Laboratorio</button
              >
            </div>
          </form>

          <div
            id="success-message"
            class="hidden absolute inset-0 bg-dent-card/95 backdrop-blur-md rounded-[2.5rem] flex-col items-center justify-center text-center p-8 z-50"
          >
            <h3 class="text-3xl font-black text-white italic uppercase tracking-tighter">
              ¡Trabajo Enviado!
            </h3>
          </div>
        </section>

        <section
          class="bg-dent-card border border-dent-border rounded-[2.5rem] p-6 flex flex-col hover:border-dent-accent/30 transition-all shadow-xl h-full min-h-[450px]"
        >
          <h2
            class="text-sm font-black text-white mb-6 flex items-center gap-3 uppercase tracking-widest"
          >
            <span class="relative flex h-3 w-3">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-dent-accent opacity-75"
              ></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-dent-accent"></span>
            </span>
            Mensajes del Lab
          </h2>

          <div class="flex-1 space-y-4 overflow-y-auto pr-2 custom-scrollbar">
            {
              ultimasNotificaciones.length === 0 ? (
                <p class="text-slate-600 text-center py-20 text-[10px] font-black uppercase italic">
                  Bandeja vacía
                </p>
              ) : (
                ultimasNotificaciones.map((notif) => (
                  <a
                    href={`/dashboard/cliente/trabajo/${notif.id_archivo}`}
                    class="block p-4 rounded-2xl bg-dent-dark/30 border border-white/5 hover:border-dent-accent/50 transition-all group"
                  >
                    <div class="flex justify-between items-center mb-2">
                      <span class="text-[9px] font-black text-dent-accent uppercase bg-dent-accent/10 px-2 py-0.5 rounded">
                        {notif.archivo.nombre_archivo}
                      </span>
                      <span class="text-[9px] font-bold text-slate-500">
                        {new Date(notif.fecha_envio).toLocaleTimeString([], {
                          hour: "2-digit",
                          minute: "2-digit",
                        })}
                      </span>
                    </div>
                    <p class="text-[11px] text-slate-400 line-clamp-2 italic group-hover:text-white transition-colors">
                      <span class="text-slate-200 font-bold not-italic mr-1">
                        {notif.emisor.name}:
                      </span>{" "}
                      "{notif.contenido}"
                    </p>
                  </a>
                ))
              )
            }
          </div>
        </section>
      </div>

      <section
        class="bg-dent-card border border-dent-border rounded-[2.5rem] p-6 md:p-8 hover:border-dent-accent/30 transition-all shadow-xl"
      >
        <div class="flex items-center justify-between mb-8">
          <div class="flex items-center gap-4">
            <div class="p-3 bg-emerald-500/10 rounded-xl">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 text-emerald-400"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                ><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
                ></path><polyline points="14 2 14 8 20 8"></polyline></svg
              >
            </div>
            <h2 class="text-sm font-black text-white uppercase tracking-widest">
              Estado Reciente de Trabajos
            </h2>
          </div>
          <a
            href="/dashboard/cliente/historial"
            class="text-dent-accent text-[10px] font-black uppercase tracking-widest hover:text-white transition-colors"
            >Ver Todo →</a
          >
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {
            misTrabajos.length === 0 ? (
              <p class="col-span-full text-slate-600 text-[10px] font-black uppercase text-center py-8">
                Sin actividad reciente
              </p>
            ) : (
              misTrabajos.map((trabajo) => (
                <a
                  href={`/dashboard/cliente/trabajo/${trabajo.id_archivo}`}
                  class="flex justify-between items-center p-4 bg-dent-dark/20 rounded-2xl border border-white/5 hover:border-dent-accent/20 transition-all group"
                >
                  <div class="flex flex-col min-w-0">
                    <span class="text-[11px] text-slate-100 font-bold truncate group-hover:text-dent-accent">
                      {trabajo.nombre_archivo}
                    </span>
                    <span class="text-[9px] text-slate-500 font-medium">
                      {new Date(trabajo.fecha_subida).toLocaleDateString("es-ES")}
                    </span>
                  </div>
                  <div
                    class={`px-2 py-1 rounded-lg text-[8px] font-black uppercase tracking-tighter ${trabajo.estado === "pendiente" ? "bg-amber-500/10 text-amber-500" : "bg-emerald-500/10 text-emerald-500"}`}
                  >
                    {trabajo.estado}
                  </div>
                </a>
              ))
            )
          }
        </div>
      </section>
    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById("upload-form") as HTMLFormElement;
  const fileInput = document.getElementById("file-upload") as HTMLInputElement;
  const preview = document.getElementById("file-name-preview");
  const dropzone = fileInput?.closest("label");

  // DRAG & DROP
  ["dragenter", "dragover", "dragleave", "drop"].forEach((name) => {
    dropzone?.addEventListener(
      name,
      (e) => {
        e.preventDefault();
        e.stopPropagation();
      },
      false
    );
  });

  ["dragenter", "dragover"].forEach((name) => {
    dropzone?.addEventListener(
      name,
      () => {
        dropzone.classList.add("border-dent-accent", "bg-dent-accent/10", "scale-[1.02]");
      },
      false
    );
  });

  ["dragleave", "drop"].forEach((name) => {
    dropzone?.addEventListener(
      name,
      () => {
        dropzone.classList.remove("border-dent-accent", "bg-dent-accent/10", "scale-[1.02]");
      },
      false
    );
  });

  dropzone?.addEventListener(
    "drop",
    (e) => {
      const files = e.dataTransfer?.files;
      if (files?.length) {
        fileInput.files = files;
        fileInput.dispatchEvent(new Event("change"));
      }
    },
    false
  );

  fileInput?.addEventListener("change", () => {
    if (fileInput.files?.length) {
      // Verificamos si es STL (por extensión)
      const file = fileInput.files[0];
      if (!file.name.toLowerCase().endsWith(".stl")) {
        alert("Error: Solo se permiten archivos .STL");
        fileInput.value = ""; // <--- ESTO ES LO QUE NECESITAS: Limpia el input
        preview?.classList.add("hidden"); // Oculta el preview si existía
        return;
      }

      if (preview) {
        preview.innerText =
          fileInput.files.length === 1
            ? `📄 ${file.name}`
            : `📚 ${fileInput.files.length} archivos .STL`;
        preview.classList.remove("hidden");
      }
    }
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData();
    const files = fileInput.files;
    const descripcion = (form.querySelector("textarea") as HTMLTextAreaElement).value;
    const prioridad = (form.querySelector("select") as HTMLSelectElement).value;

    if (!files?.length) return alert("Selecciona un archivo primero");

    for (const file of files) formData.append("files", file);
    formData.append("descripcion", descripcion);
    formData.append("prioridad", prioridad);

    try {
      const response = await fetch("/api/upload", { method: "POST", body: formData });
      if (response.ok) {
        document.getElementById("success-message")?.classList.remove("hidden");
        document
          .getElementById("success-message")
          ?.classList.add("flex", "animate-in", "zoom-in-95", "duration-500");
        setTimeout(() => location.reload(), 3000);
      } else {
        const res = await response.json();
        alert("Atención: " + res.error);
      }
    } catch (err) {
      alert("Error de conexión");
    }
  });
</script>
